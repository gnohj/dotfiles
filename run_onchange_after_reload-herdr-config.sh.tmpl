#!/usr/bin/env bash
# herdr-config-reload version: 1   (bump to force a re-run on `chezmoi apply`)
#
# config.toml hash: {{ include "dot_config/herdr/config.toml" | sha256sum }}
#
# Reload the RUNNING herdr server after chezmoi rewrites config.toml. herdr reads
# keybindings into memory ONCE at startup, so on-disk changes silently drift on the
# live server until restart. The hash line above re-triggers this only on real changes.
set -uo pipefail

# Fresh box: herdr may not be installed yet. Exit 0 (config is on disk; first start reads it).
command -v herdr >/dev/null 2>&1 || { echo "herdr not on PATH yet; skipping config reload"; exit 0; }

# reload-config is a client->server RPC; tolerate failure when no server is live.
if herdr server reload-config >/dev/null 2>&1; then
  echo "herdr: reloaded running server config"
else
  echo "herdr: no running server to reload (config applies on next start)"
fi
exit 0
