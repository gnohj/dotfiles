# Pattern A worktree workflow: keep `origin/HEAD` (and the rest of
# `refs/remotes/origin/*`) fresh in the bare repo so any tool that
# branches off `origin/HEAD` ‚ÄĒ `treekanga add ‚Ä¶ -b origin/HEAD`,
# lazygit, manual `git checkout -b ‚Ä¶ origin/master` ‚ÄĒ sees the latest
# remote without the user thinking about it. The AI flows
# (worktree-prompt fast-path, /worktree skill) already fetch before
# branching; this hook covers manual TUI usage of lazygit/treekanga.
#
# Behavior:
#   ‚ÄĘ Fires only when cwd is inside `$HOME/Developer/<repo>/...`.
#   ‚ÄĘ Debounced via `<bare>/.last-fetch` stamp ‚ÄĒ at most once every
#     5 minutes per repo to avoid network thrash on rapid `cd` chains.
#   ‚ÄĘ Background + disowned (`&!`) so prompts never block.
#   ‚ÄĘ Silent on failure (offline, auth blip) ‚ÄĒ never disrupts cd.
_worktree_autofetch_origin() {
  case "$PWD" in
    "$HOME/Developer/"*) ;;
    *) return ;;
  esac
  local repo_root="${PWD#$HOME/Developer/}"
  repo_root="${repo_root%%/*}"
  local bare="$HOME/Developer/$repo_root/.bare"
  [[ -d "$bare" ]] || return

  local stamp="$bare/.last-fetch"
  local now=$(date +%s)
  local last=0
  [[ -f "$stamp" ]] && last=$(<"$stamp") 2>/dev/null
  (( now - last < 300 )) && return

  # --prune cleans up remote-tracking refs whose upstream branches were
  # deleted (merged PR cleanup, dependabot churn, etc.). Free side
  # effect every 5 min ‚ÄĒ keeps `git branch -r` and lazygit's branch
  # list from accumulating dead refs.
  ( git -C "$bare" fetch origin --quiet --prune 2>/dev/null && print -n "$now" > "$stamp" ) &!
}
add-zsh-hook chpwd _worktree_autofetch_origin

