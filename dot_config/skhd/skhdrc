# On MacOS, you need to add Aerospace via 'enable allows applications to monitor keyboard input' in Privacy & Security
# Make sure that aerospace path is the pointing to the correct binary (Depending on your installation method)

# Available keys - rctrl -

# Terminal cancel shortcut - Ctrl+Space sends Ctrl+C
lctrl - space : skhd -k "ctrl - c"

# Disable minimize/hide
cmd + shift - q : osascript -e 'tell application "System Events" to set frontApp to name of first application process whose frontmost is true' -e 'tell application frontApp to quit'
cmd - m : :
cmd - h : :

# Tmux window navigation
rctrl - tab : /opt/homebrew/bin/tmux next-window # grave/backtick key (0x32)
rctrl - 0x32 : /opt/homebrew/bin/tmux previous-window # shift + grave for previous
rctrl - space : /opt/homebrew/bin/tmux last-window # toggle between last two windows

# Tmux window selection by number (windows are 0-indexed)
rctrl - 1 : /opt/homebrew/bin/tmux select-window -t :0
rctrl - 2 : /opt/homebrew/bin/tmux select-window -t :1
rctrl - 3 : /opt/homebrew/bin/tmux select-window -t :2
rctrl - 4 : /opt/homebrew/bin/tmux select-window -t :3
rctrl - 5 : /opt/homebrew/bin/tmux select-window -t :4
rctrl - 6 : /opt/homebrew/bin/tmux select-window -t :5
rctrl - 7 : /opt/homebrew/bin/tmux select-window -t :6
rctrl - 8 : /opt/homebrew/bin/tmux select-window -t :7
rctrl - 9 : /opt/homebrew/bin/tmux select-window -t :8
rctrl - 0 : /opt/homebrew/bin/tmux list-windows -F '#{window_index}' | tail -n +2 | sort -rn | xargs -I{} /opt/homebrew/bin/tmux kill-window -t :{}

# Tmux smart dual split switching (remembers Neovim buffers)
rctrl - b : ~/.config/skhd/smart-tmux-dual-split-switch.sh
# Tmux smart dual split creation (70/30 split on first pane)
rctrl - f : ~/.config/skhd/smart-tmux-dual-split-create.sh

# Launcher - Omarchy-style popup launcher
rctrl - i : /opt/homebrew/bin/tmux display-popup -E -w 30% -h 40% ~/.config/launcher/launcher.sh
rctrl - y : ~/.config/skhd/yazi-launch.sh

# rctrl - a : ~/.config/skhd/tmux-window-simple.sh 🤖 ai /opt/homebrew/bin/opencode true
rctrl - a : ~/.config/skhd/tmux-window-simple.sh 🤖 ai "/opt/homebrew/bin/pi -c" true
rctrl - v : ~/.config/skhd/tmux-window-simple.sh 🐑 herd "/opt/homebrew/bin/herdr" true
rctrl - e : ~/.config/skhd/tmux-window-simple.sh 🖊️ pen nvim
# rctrl - x : top/bottom horizontal split (see line below for binding)
# rctrl - c : freed for native tmux copy
rctrl + shift - x : ~/.config/skhd/tmux-window-simple.sh 🐠 shell
rctrl - 0x2F : /opt/homebrew/bin/tmux split-window -h -c "#{pane_current_path}" # new pane in current directory (period)
rctrl - 0x2C : /opt/homebrew/bin/tmux display-popup -E -w 80% -h 80% "$HOME/.cargo/bin/recon" # recon claude dashboard (forward slash)
rctrl - escape : /opt/homebrew/bin/terminal-notifier -remove ALL >/dev/null 2>&1; killall NotificationCenter usernotificationsd; rm -f /tmp/notify-idle.latest # clear stuck banners + state
# codeburn dashboard moved to rctrl-i launcher menu
# rctrl - r - reserved for atuin
rctrl - 0x24 : /opt/homebrew/bin/tmux switch-client -l
# rctrl - d - reserved for nvim shortcut (remapped <C-d> to <rctrl - d>) to scroll down in nvim
# rctrl - u - reserved for nvim shortcut (remapped <C-u> to <rctrl - u>) to scroll up in nvim
# rctrl - o - reserved for nvim shortcut (remapped <C-o> to <rctrl - o>) to jump back in nvim
# rctrl - i - moved above to launcher
# rctrl - w - reserved for nvim shortcut (remapped <C-w> to <rctrl - w>) to do window management in nvim
# rctrl - s - reserved for nvim shortcuts - open buffers in split - horizontal / vertical ; in normal mode it'll save the file
# rctrl - y - reserved for nvim - open noice history
# rctrl - p - reserved for nvim - reserved for going to next history
# rctrl - n - reserved for nvim - reserved for going to previous history
# rctrl - h/j/k/l - reserved for nvim - navigation
rctrl - g : ~/.config/skhd/lazygit.sh
rctrl + shift - g : ~/.config/skhd/tmux-window-simple.sh 🌳 lazygit "HUSKY=0 LG_CONFIG_FILE=~/.config/lazygit/config.yml lazygit" true
rctrl - t : ~/.config/skhd/sesh-switcher.sh
rctrl - 0x29 : ~/.config/skhd/treekanga-selector.sh # semicolon
rctrl - 0x27 : ~/.local/bin/notify-idle-switch.sh # single quote — smart switch: tmux-attach to latest banner's session + clear
rctrl + shift - d : ~/.local/bin/agent-sidebar-dashboard.sh # toggle/summon agent sidebar dashboard on workspace T
rctrl + shift - t : ~/.config/tmux/toggle-terminal-transparency.sh
rctrl + shift - j : ~/.local/bin/worktree-jira # active Chrome Jira tab → /worktree (subscription-billed)
rctrl + shift - h : ~/.local/bin/worktree-prompt # tmux popup prompt → /worktree (free-text inference)
rctrl + shift - k : ~/.local/bin/worktree-clipboard # clipboard (text or image) → classify + /worktree
rctrl + shift - b : ~/.local/bin/worktree-bug # clipboard → classify-as-bug + create Jira ticket + /worktree
rctrl + shift - r : ~/.local/bin/worktree-retry # retry the most-recent worktree-bug capture (refine context)
rctrl + shift - f : ~/.local/bin/worktree-jira-file # Stage B: file the Jira ticket from the current worktree's pending note (dry-run preview → confirm → file)
rctrl + shift - escape : ~/.local/bin/worktree-abort # abort the most recent worktree-runner in flight
rctrl - c : /opt/homebrew/bin/tmux copy-mode
rctrl - x : /opt/homebrew/bin/tmux split-window -v -l 20% -c "#{pane_current_path}" # new pane below at 20% height (tweak with -l N%)
rctrl + shift - c : /opt/homebrew/bin/tmux neww ~/.config/colorscheme/colorscheme-selector.sh
# rctrl - q - reserved for nvim shortcut to quit nvim instance
rctrl - z : /opt/homebrew/bin/tmux kill-pane
rctrl - m : /opt/homebrew/bin/tmux resize-pane -L 5
rctrl - 0x2B : /opt/homebrew/bin/tmux resize-pane -R 5 # comma
