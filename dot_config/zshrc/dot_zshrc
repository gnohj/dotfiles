# Copy the current git branch name to the clipboard.
gbc() {
  local branch
  branch=$(git branch --show-current 2>/dev/null)
  if [[ -z "$branch" ]]; then
    echo "Not in a git repository" >&2
    return 1
  fi
  printf '%s' "$branch" | pbcopy
  echo "Copied branch: $branch"
}

# Open the GitHub PR for the current branch in a browser. If no PR exists,
# fall back to the repo's open-PRs list (sorted by recently-updated).
pullreq() {
  if gh pr view --web 2>/dev/null; then
    return 0
  fi
  # Detached HEAD (e.g. a review worktree) has no current branch, so the
  # lookup above fails. Recover the branch from the remote ref pointing at
  # HEAD (remote-agnostic) and open that branch's PR.
  if [[ -z "$(git symbolic-ref -q --short HEAD 2>/dev/null)" ]]; then
    local detached_ref detached_branch
    detached_ref=$(git branch --points-at HEAD -r --format='%(refname:short)' 2>/dev/null | grep -v '/HEAD$' | head -n1)
    detached_branch=${detached_ref#*/}
    if [[ -n "$detached_branch" ]] && gh pr view "$detached_branch" --web 2>/dev/null; then
      echo "Opened PR for detached-HEAD branch: $detached_branch"
      return 0
    fi
  fi
  local repo
  repo=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
  if [[ -z "$repo" ]]; then
    echo "Could not resolve repo (not a git repo or gh not authenticated)" >&2
    return 1
  fi
  open "https://github.com/$repo/pulls?q=sort%3Aupdated-desc+is%3Apr+is%3Aopen"
  echo "No PR for branch ‚ÄĒ opened $repo PRs list"
}

# Parse a Jira ticket key (e.g. IHRWEB-23658) from the current branch name
# and open the corresponding ticket in the browser.
ticket() {
  local branch key
  branch=$(git branch --show-current 2>/dev/null)
  if [[ -z "$branch" ]]; then
    echo "Not in a git repository" >&2
    return 1
  fi
  key=$(printf '%s' "$branch" | grep -oE '[A-Z]+-[0-9]+' | head -n1)
  if [[ -z "$key" ]]; then
    echo "No Jira ticket key found in branch: $branch" >&2
    return 1
  fi
  open "https://ihm-it.atlassian.net/browse/$key"
  echo "Opened ticket: $key"
}

# Show dirty/clean state for git repos with a file-level breakdown. Repos come
# from `tmux-dash json --dirty --clean` (every git-source repo, each tagged with
# a `dirty` bool), shared with the sketchybar dirty-repos widget (which uses
# just `--dirty` for its count) so the two stay in lockstep on scope.
dirty() {
  # --list: show every repo in scope with its status, no file-level breakdown.
  if [[ "${1:-}" == "--list" ]]; then
    local d p display
    while IFS=$'\t' read -r d p; do
      [[ -z "$p" ]] && continue
      display="${p/#$HOME/~}"
      if [[ "$d" == "true" ]]; then
        printf "\033[33m‚óŹ dirty\033[0m  %s\n" "$display"
      else
        printf "\033[32m‚úď clean\033[0m  %s\n" "$display"
      fi
    done < <(tmux-dash json --dirty --clean 2>/dev/null | jq -r '.repos[] | "\(.dirty)\t\(.path)"')
    return
  fi

  local dirty_paths=() clean_paths=()
  local d p
  while IFS=$'\t' read -r d p; do
    [[ -z "$p" ]] && continue
    if [[ "$d" == "true" ]]; then
      dirty_paths+=("$p")
    else
      clean_paths+=("$p")
    fi
  done < <(tmux-dash json --dirty --clean 2>/dev/null | jq -r '.repos[] | "\(.dirty)\t\(.path)"')

  if [ ${#dirty_paths[@]} -eq 0 ]; then
    echo ""
    echo "\033[32m All repos clean:\033[0m"
    for cp in "${clean_paths[@]}"; do
      echo "\033[32m  ${cp/#$HOME/~}\033[0m"
    done
    return
  fi

  for r in "${dirty_paths[@]}"; do
    local repo_status=$(git -C "$r" status --porcelain 2>/dev/null)
    local unpushed=$(git -C "$r" rev-list --count @{u}..HEAD 2>/dev/null)
    local display_name="${r/#$HOME/~}"
    echo ""
    printf "\033[1;38;2;167;207;189m\U000f062c %s\033[0m\n" "$display_name"
    if [ -n "$repo_status" ]; then
      echo "$repo_status" | while IFS= read -r line; do
        local xy="${line:0:2}"
        local x="${xy:0:1}" y="${xy:1:1}"
        if [[ "$xy" == "??" ]]; then
          echo "\033[35m ?? $line\033[0m"                # magenta - untracked
        elif [[ "$x" != " " && "$y" != " " && "$xy" != "??" ]]; then
          echo "\033[33m ‚óŹ $line\033[0m"                 # yellow - staged + unstaged
        elif [[ "$x" != " " ]]; then
          echo "\033[32m ‚úď $line\033[0m"                 # green - staged
        elif [[ "$y" != " " ]]; then
          echo "\033[31m ‚úó $line\033[0m"                 # red - unstaged
        else
          echo "  $line"
        fi
      done
    fi
    [ "${unpushed:-0}" -gt 0 ] && echo "\033[1;36m  ‚ÜĎ $unpushed unpushed commit(s)\033[0m"
  done
}

# Fetch remote branches matching a pattern
# Usage: fetch-origin release/  - fetches all branches matching release/*
fetch-origin() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: Not in a git repository" >&2
    return 1
  fi

  local pattern="${1:-}"
  if [[ -z "$pattern" ]]; then
    echo "Usage: fetch-origin <pattern>"
    echo "Example: fetch-origin release/"
    return 1
  fi

  # List remote refs matching pattern
  local refs=$(git ls-remote --heads origin 2>/dev/null | awk '{print $2}' | grep "$pattern" | sed 's|refs/heads/||')

  if [[ -z "$refs" ]]; then
    echo "No branches matching '$pattern' found on origin"
    return 1
  fi

  local count=$(echo "$refs" | wc -l | tr -d ' ')
  echo "Fetching $count branches matching '$pattern'..."

  # Fetch all matching refs in one command
  git fetch origin ${(f)refs}
}
