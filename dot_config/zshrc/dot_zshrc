# herdr launch wrapper ‚ÄĒ force --remote-keybindings server on `herdr --remote <host>`
# so our type=shell helpers (prefix+=, prefix+f) run ON THE REMOTE server, where the
# panes and socket live. herdr's default is `local`, which would run them on this
# laptop against the wrong/absent socket. type=pane binds (lazygit/yazi/sesh) are
# server-side regardless. Bare `herdr` and subcommands pass straight through.
herdr() {
  if [[ $1 == --remote && " $* " != *" --remote-keybindings "* ]]; then
    command herdr --remote-keybindings server "$@"
  else
    command herdr "$@"
  fi
}

# btopc / btopm: proc-only fullscreen tables, cpu- or memory-sorted ("cpu direct" is a strict live top-to-bottom sort; "cpu lazy" smooths order over time and looks unsorted).
_btop_proc_conf() {
  local sort="$1" tag="${1// /-}"
  local tmp="${TMPDIR:-/tmp}/btop-proc-${tag}.conf"
  sed -E -e "s/^proc_sorting = .*/proc_sorting = \"$sort\"/" \
         -e 's/^shown_boxes = .*/shown_boxes = "proc"/' \
    ~/.config/btop/btop.conf >"$tmp"
  print -r -- "$tmp"
}
btopc() { command btop -c "$(_btop_proc_conf 'cpu direct')" "$@"; }
btopm() { command btop -c "$(_btop_proc_conf memory)" "$@"; }
# btop2 ‚ÄĒ btopm (memory) left, btopc (cpu) right, proc-only, side by side
btop2() {
  if [[ -z "$TMUX" ]]; then
    echo "btop2 needs tmux; run btopm and btopc in separate splits instead"
    return 1
  fi
  tmux split-window -h "btop -c '$(_btop_proc_conf 'cpu direct')'"
  tmux select-pane -L
  command btop -c "$(_btop_proc_conf memory)"
}

