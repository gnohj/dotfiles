# Claude Code: `cs` (start) and `cr` (resume) live in ~/.local/bin/.

# ‚ĒÄ‚ĒÄ‚ĒÄ Claude Code multi-account ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
# Same binary, different config dirs (sessions + creds are fully isolated):
#   ~/.claude       personal account (the default dir)
#   ~/.claude-work  work account
# Run `/login` once inside each to authenticate it.
#
# The account is chosen automatically from the current dir's git remote (iHeart
# org ‚Üí work, else personal) by the `claude-account` script (~/.local/bin), which
# also hands back the matching config dir + OAuth token. `claude`, `cs`, `cr`, and
# the nvim dashboard all go through it, so just `cd` into a repo and launch.
# Force a different account for THIS shell with `cw` (toggle) / `cauto` (clear).
claude() {
	local dir tok claude_bin
	local -a mode
	# Resolve the real binary at call time (whence -p skips this function), not at
	# load time ‚ÄĒ on Linux the mise `claude` shim isn't on PATH until mise activates
	# later in this file, so a load-time lookup fell back to a Mac-only homebrew path.
	claude_bin="$(whence -p claude 2>/dev/null || echo claude)"
	dir="${CLAUDE_CONFIG_DIR:-$(claude-account dir)}"
	tok="${CLAUDE_CODE_OAUTH_TOKEN:-$(claude-account token)}"
	# settings.json sets permissions.defaultMode = "bypassPermissions" so herdr's
	# flagless session-resume (resume_agents_on_restore) comes back in bypass mode
	# after a reboot instead of a locked-down pane. A fresh interactive `claude`
	# should stay safe, so force --permission-mode default here ‚ÄĒ but ONLY for a new
	# session. A resume/continue (herdr's restore path, or a manual `claude -r`) must
	# inherit the bypass default, so skip the override when a resume flag is present.
	case " $* " in
		*" -r "*|*" --resume "*|*" -c "*|*" --continue "*) ;;
		*) mode=(--permission-mode default) ;;
	esac
	# Subshell so the conditional exports don't leak into the parent shell.
	# Personal leaves CLAUDE_CONFIG_DIR unset (native default config); only work
	# sets it. Token is injected when one is stored for the resolved account.
	(
		[ -n "$dir" ] && export CLAUDE_CONFIG_DIR="$dir"
		[ -n "$tok" ] && export CLAUDE_CODE_OAUTH_TOKEN="$tok"
		exec "$claude_bin" "${mode[@]}" "$@"
	)
}

# Per-shell account override (exported so cs/cr/claude children inherit it).
# `cw` flips to the OTHER account for this shell; `cauto` returns to automatic.
cw() {
	local cur
	cur="${CLAUDE_ACCOUNT:-$(claude-account resolve)}"
	[ "$cur" = work ] && export CLAUDE_ACCOUNT=personal || export CLAUDE_ACCOUNT=work
	echo "CLAUDE_ACCOUNT ‚Üí $CLAUDE_ACCOUNT (this shell; run cauto for auto)"
}
alias cauto='unset CLAUDE_ACCOUNT && echo "CLAUDE_ACCOUNT cleared ‚Üí auto (by git remote)"'

