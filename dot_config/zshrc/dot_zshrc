    sketchybar --add event package_update 2>/dev/null
    sketchybar --subscribe widgets.package_notification package_update 2>/dev/null

    # Brew wrapper function
    function brew() {
        command arch -arm64 brew "$@"
        local exit_code=$?
        # Trigger on commands that change state (brew has already finished here)
        case "$1" in
            install|uninstall|upgrade|update)
                sketchybar --trigger package_update 2>/dev/null &
                ;;
        esac
        # Reload sketchybar after an upgrade so widgets pick up new binaries
        if [[ "$1" == "upgrade" ]]; then
            sketchybar --reload 2>/dev/null &
        fi
        return $exit_code
    }

    # MAS wrapper function
    if command -v mas &>/dev/null; then
        function mas() {
            command mas "$@"
            local exit_code=$?
            # Trigger on commands that change state (mas has already finished here)
            case "$1" in
                install|uninstall|upgrade)
                    sketchybar --trigger package_update 2>/dev/null &
                    ;;
            esac
            # Reload sketchybar after an upgrade so widgets pick up new apps
            if [[ "$1" == "upgrade" ]]; then
                sketchybar --reload 2>/dev/null &
            fi
            return $exit_code
        }
    fi
fi

