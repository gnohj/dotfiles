#!/usr/bin/env bash
# Obsidian: create a new inbox note from the command line.
# All real work (path construction, template expansion, naming convention)
# lives in dot_config/nvim/lua/config/obsidian.lua so this script, the
# dashboard "Second Brain (New)" action, and <leader>zN stay in sync.

if [ -z "$1" ]; then
  echo 'Usage: on "note title"'
  exit 1
fi

# Pass the title via env var so it round-trips to lua without quote-escape
# headaches that come from interpolating into a -c command string.
OBSIDIAN_INBOX_TITLE="$*" \
  exec nvim -c 'lua require("config.obsidian").new_inbox_note(vim.env.OBSIDIAN_INBOX_TITLE)'
