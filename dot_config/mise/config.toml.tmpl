# mise configuration - Language runtimes ONLY
# https://mise.jdx.dev/configuration.html
#
# Migration strategy (see ~/.local/share/chezmoi/dot_nix/README.md): Nix owns
# system packages & ALL CLI tools; mise (this file) owns language runtimes ONLY;
# Homebrew (nix-darwin) owns macOS-specific apps & services.

[tools]
# Note: Node 22 is also installed for Neovim Copilot (see ~/.config/nvim/lua/plugins/copilot.lua)
node = { version = 'lts', postinstall = 'corepack enable' }
lua = '5.4'
python = 'latest'
go = 'latest'
rust = 'latest'
bun = 'latest'
zig = 'latest'          # used for GhosttyFetch

"npm:prettier" = "latest"
"npm:codeburn" = "latest"
{{- if ne .chezmoi.os "darwin" }}

# Linux VPS: no Nix layer, so mise owns the whole CLI toolchain (on macOS these come from nix-darwin/Homebrew). Declarative so `mise install` fetches them all with retries, instead of a best-effort `mise use -g` loop that silently skips a tool when a GitHub lookup blips.
# Two-tier pinning: config-format-sensitive tools pinned to the macOS/nix minor line (a breaking bump can't silently land on the VPS and desync the shared dotfiles; partial pins still let patches flow via `mise upgrade`); plain CLIs stay "latest". Bump a pin, then run `up` on each box.
neovim = "0.12"         # nvim config/API can break across minors
starship = "1"          # starship.toml format stable across v1
yazi = "26.5"           # yazi keymap/theme format breaks across minors
"ubi:arl/gitmux" = "0.11.5"          # pre-1.0; exact (ubi partial-match unreliable)
"aqua:joshmedeski/sesh" = "2.27.0"   # exact (aqua partial-match unreliable)
ripgrep = "latest"
fd = "latest"
fzf = "latest"
lazygit = "latest"
bat = "latest"
eza = "latest"
zoxide = "latest"
jq = "latest"
gh = "latest"
btop = "latest"
delta = "latest"
yq = "latest"
television = "latest"
lazydocker = "latest"
pnpm = "latest"
atuin = "latest"
"ubi:dlvhdr/gh-dash" = "latest"
"ubi:kunchenguid/treehouse" = "latest"
"ubi:kunchenguid/no-mistakes" = "latest"
"ubi:garrettkrohn/treekanga" = "latest"
# claude-code + codex ship a platform-native binary via a postinstall script; mise's npm backend passes --ignore-scripts=true by default, so opt back in for these two or `claude`/`codex` install the JS wrapper but not the native binary.
"npm:@anthropic-ai/claude-code" = { version = "latest", npm_args = "--ignore-scripts=false" }
"npm:@openai/codex" = { version = "latest", npm_args = "--ignore-scripts=false" }
"npm:@google/gemini-cli" = "latest"
{{- end }}

[tasks]
# aic is configured via chezmoi template at ~/.aicommitrc (see dot_aicommitrc.tmpl);
# uses GitHub Copilot Enterprise via GitHub Models with a dynamic 'gh auth token'.
install-aicommit = "bun add -g @kkidd/aicommit"
setup-global-tools = "mise run install-aicommit"

[settings]
auto_install = true
experimental = true
idiomatic_version_file_enable_tools = ["node"]
# trusted_config_paths intentionally lives in $MISE_TRUSTED_CONFIG_PATHS (~/.zshenv),
# NOT here. mise honors trusted_config_paths ONLY from the GLOBAL config, but this
# exact file is ALSO seen as a NON-global (local) config whenever a shell is cd'd
# inside the chezmoi source tree (mise walks up and finds
# ~/.local/share/chezmoi/dot_config/mise/config.toml). It then warns
# "trusted_config_paths in non-global config ... is ignored for security reasons" on
# every command. Keeping the key out of every config file entirely means that warning
# never fires; the env var provides the same trust with no such restriction.
