# Cache command output to speed up shell startup
_evalcache() {
  # NOTE: split into two lines ‚ÄĒ zsh evaluates the rhs of all `local` pairs
  # BEFORE any of the assignments take effect, so combining them on one line
  # makes `$name` in `cache=...` reference the OUTER scope (often empty),
  # producing a stale `.zsh` cache file shared across every invocation.
  local name=$1
  local cache="$ZDOTDIR/.zsh_cache/$name.zsh"
  shift
  [[ -d "$ZDOTDIR/.zsh_cache" ]] || mkdir -p "$ZDOTDIR/.zsh_cache"
  if [[ ! -s "$cache" || "$(which $1)" -nt "$cache" ]]; then
    "$@" > "$cache" 2>/dev/null
  fi
  [[ -s "$cache" ]] && source "$cache"
}

