# Repos that github-auto-push.sh should auto-commit & push.
# Format: one path per line. Comments start with #.
#
# This is separate from repos-clone.txt (which is the clone manifest used by
# user-setup.sh) so that paths can be auto-pushed without being cloned at
# setup time — e.g. fitness lives in the iCloud-synced vault but its
# GitHub remote is preserved as an off-machine backup.
#
# Templated per-OS: the personal vault + its nested project repos exist only on
# macOS (iCloud-backed). The Linux work VPS has no personal vault, so listing
# them there would just make the auto-push script cd into missing paths.

~/Developer/gnohj-monorepo
{{- if eq .chezmoi.os "darwin" }}
~/Obsidian/second-brain
~/Obsidian/second-brain/Projects/banking
~/Obsidian/second-brain/Projects/fitness
~/Obsidian/second-brain/Projects/parents-estate
{{- end }}
# second-brain-work (work vault) is intentionally NOT autopushed on ANY machine —
# work commits are deliberate. It is cloned via repos-clone.txt but never auto-committed.
~/Developer/agents
~/Developer/colorscheme
~/Developer/tmux-dash
{{- if eq .chezmoi.os "darwin" }}
# vps-linux-provision: auto-push from the Mac only, never from the VPS itself.
~/Developer/vps-linux-provision
{{- end }}
