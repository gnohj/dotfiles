#!/usr/bin/env bash
# Free-text describe → /worktree pipeline. Opens a tmux popup asking
# for a loose description (e.g., "web infra release-automation"), then
# hands off to ~/.local/bin/worktree-runner — the shared backend that
# spawns Terminal.app, runs `claude -p "/worktree <input> --yes"`, and
# fires start/ready/failed banners.
#
# This entry point owns ONLY input capture + Mode-B disambiguation.
# Everything after `exec worktree-runner` is shared with worktree-jira,
# worktree-clipboard, worktree-bug, and any future capture method.
#
# Bind via skhd, e.g.:
#   rctrl + shift - h : ~/.local/bin/worktree-prompt

set -euo pipefail

# skhd spawns this with a minimal PATH. Pin a sensible PATH so tmux,
# resolve-term-icon, claude, etc. resolve.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# When fired by skhd, this script runs OUTSIDE any tmux client context —
# `tmux display-popup` then has no client to host the popup on and the
# script appears to "just close". The launcher menu invocation uses
# `tmux run-shell -b worktree-prompt`, which re-enters the tmux server
# context so the popup renders correctly. Mirror that here when we
# detect we're not inside a tmux client AND a tmux server is up.
#
# Re-spawning via `tmux run-shell -b` is fire-and-forget — once it
# launches the script in tmux's context, this outer process exits.
if [ -z "${TMUX:-}" ] \
   && [ -z "${WORKTREE_PROMPT_RESPAWNED:-}" ] \
   && command -v tmux >/dev/null 2>&1 \
   && tmux ls >/dev/null 2>&1; then
  WORKTREE_PROMPT_RESPAWNED=1 tmux run-shell -b "$HOME/.local/bin/worktree-prompt"
  exit 0
fi

# Capture the user's typed input via a tmux popup. tmux display-popup
# expects the inner command as a SINGLE shell-command arg (not split with
# `--`), so we stage the popup script in a tmp file and invoke that.
INPUT_FILE=$(mktemp -t worktree-prompt.XXXXXX)
POPUP_SH=$(mktemp -t worktree-prompt-popup.XXXXXX.sh)
chmod +x "$POPUP_SH"
trap 'rm -f "$INPUT_FILE" "$POPUP_SH"' EXIT

cat > "$POPUP_SH" <<EOF
#!/usr/bin/env bash
clear
cat <<EXAMPLES
Worktree from description (claude infers repo · folder · slug)

Examples:
  web infra release-automation
  inferno fix oauth-redirect-bug
  web feat new-search-ui
  web spike fastly-edge-rendering

Format: <repo> <folder-hint> <slug>   (space-separated, loose)

(Ctrl-C to cancel · Enter to submit)

EXAMPLES
read -e -p "> " input
[ -n "\$input" ] && echo "\$input" > "$INPUT_FILE"
EOF

# `-w 70% -h 30%` sizes generously to fit the example block. -E closes
# the popup when POPUP_SH exits.
tmux display-popup -E -w 70% -h 30% "$POPUP_SH"

INPUT=$(cat "$INPUT_FILE" 2>/dev/null || true)
# Done with capture tmpfiles; clean now since `exec` won't fire the trap.
rm -f "$INPUT_FILE" "$POPUP_SH"
if [ -z "$INPUT" ]; then
  exit 0
fi

# Preserve what the user actually typed for the log (we may rewrite below).
ORIG_INPUT="$INPUT"

# Pre-parse the common case `<repo> <bucket> <slug>` deterministically
# BEFORE handing off to claude. The /worktree skill on -p sonnet sometimes
# misclassifies this 3-token shape as Mode B (positional repo/branch/path)
# instead of Mode C (free-text describe with explicit bucket), which puts
# the worktree at `<repo>/<slug>` and silently drops the bucket.
#
# Mode B's third arg accepts `<folder>/<name>` and parses unambiguously, so
# we rewrite `<repo> <bucket> <slug>` → `<repo> <slug> <bucket>/<slug>`.
# That one shape has a single valid parse no matter which mode the LLM
# picks; the bucket survives.
#
# Free-text descriptions (anything not matching this exact shape) pass
# through unchanged — Mode C still infers via the LLM.
# Read the canonical repo allowlist from ~/.local/bin/worktree/repos.conf
# (gitignored, employer-specific). Falls back to "web inferno" if the
# file is missing or empty — keeps a fresh machine workable until
# repos.conf is populated. Blank lines and `#` comments are stripped.
#
# Portable parsing (no `mapfile`): macOS system bash is 3.2 and skhd
# fires this script with a minimal PATH that resolves `env bash` to
# /bin/bash, so we can't rely on bash-4 features here.
REPOS_CONF="$HOME/.local/bin/worktree/repos.conf"
VALID_REPOS=()
if [ -s "$REPOS_CONF" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"                    # strip inline + full-line comments
    line=$(echo "$line" | tr -d '[:space:]')  # trim all whitespace
    [ -n "$line" ] && VALID_REPOS+=( "$line" )
  done < "$REPOS_CONF"
fi
[ "${#VALID_REPOS[@]}" -eq 0 ] && VALID_REPOS=( web inferno )

read -r -a TOKENS <<< "$INPUT"
if [ "${#TOKENS[@]}" -eq 3 ]; then
  REPO="${TOKENS[0]}"
  BUCKET="${TOKENS[1]}"
  SLUG="${TOKENS[2]}"

  # Is REPO in the allowlist?
  REPO_VALID=0
  for r in "${VALID_REPOS[@]}"; do
    [ "$REPO" = "$r" ] && { REPO_VALID=1; break; }
  done

  if [ "$REPO_VALID" -eq 1 ]; then
    case "$BUCKET" in
      fix|feat|ui|infra|refactor|perf|test|chore|spike)
        # Slug must look like a leaf branch name (no slashes, no spaces).
        if [[ "$SLUG" =~ ^[A-Za-z0-9._-]+$ ]]; then
          INPUT="$REPO $SLUG $BUCKET/$SLUG"
        fi
        ;;
      *)
        # Unknown bucket — try a "did you mean?" suggestion via Levenshtein
        # distance ≤ 2 against the known bucket list. If we find a close
        # match, auto-correct AND fire a notification so the user sees
        # the correction. Falls through silently on no close match (claude
        # will still infer via /worktree's Mode C).
        SUGGEST=$(awk -v typo="$BUCKET" '
          function min3(a, b, c) {
            x = a; if (b < x) x = b; if (c < x) x = c; return x
          }
          function lev(a, b,    la, lb, i, j, cost) {
            la = length(a); lb = length(b)
            for (i = 0; i <= la; i++) m[i,0] = i
            for (j = 0; j <= lb; j++) m[0,j] = j
            for (i = 1; i <= la; i++) {
              for (j = 1; j <= lb; j++) {
                cost = (substr(a,i,1) == substr(b,j,1)) ? 0 : 1
                m[i,j] = min3(m[i-1,j]+1, m[i,j-1]+1, m[i-1,j-1]+cost)
              }
            }
            return m[la,lb]
          }
          BEGIN {
            split("fix feat ui infra refactor perf test chore spike", known, " ")
            best = ""; best_d = 999
            for (k in known) {
              d = lev(typo, known[k])
              if (d < best_d) { best_d = d; best = known[k] }
            }
            if (best_d <= 2) print best
          }')
        if [ -n "$SUGGEST" ] && [[ "$SLUG" =~ ^[A-Za-z0-9._-]+$ ]]; then
          INPUT="$REPO $SLUG $SUGGEST/$SLUG"
          mac-notify -t "Auto-corrected bucket" \
                     -m "'$BUCKET' → '$SUGGEST' (worktree at $REPO/$SUGGEST/$SLUG)" \
                     -T 5 -g "worktree-prompt-typo"
        fi
        ;;
    esac
  fi
fi

# A short label used in the banner group / file. Strip non-alphanumerics
# so it's safe across every interpolation site.
LABEL=$(echo "$INPUT" | tr -c '[:alnum:]_-' '-' | sed 's/-\{2,\}/-/g; s/^-\|-$//g' | head -c 40)

# FAST PATH — if INPUT is in canonical Mode-B-rewrite shape
# (`<repo> <slug> <bucket>/<slug>`), skip claude entirely and run
# `treekanga add` directly. Saves ~25–30s per worktree (claude
# reasoning + tool-call overhead) for the common case of typing
# `<repo> <known-bucket> <slug>` at the popup.
#
# Validation:
#   - Exactly 3 tokens
#   - Token 0 (repo) is in $VALID_REPOS
#   - Token 2 looks like `<bucket>/<slug>` where bucket is known
#     and slug == token 1 (i.e. the rewrite happened cleanly)
#   - Bare repo dir exists at ~/Developer/<repo>/.bare
FAST_PATH_CMD=""
read -r -a CANON <<< "$INPUT"
if [ "${#CANON[@]}" -eq 3 ] && [[ "${CANON[2]}" =~ ^([A-Za-z0-9._-]+)/([A-Za-z0-9._-]+)$ ]]; then
  CANON_REPO="${CANON[0]}"
  CANON_SLUG="${CANON[1]}"
  CANON_BUCKET="${BASH_REMATCH[1]}"
  CANON_SLUG2="${BASH_REMATCH[2]}"

  REPO_VALID=0
  for r in "${VALID_REPOS[@]}"; do
    [ "$CANON_REPO" = "$r" ] && { REPO_VALID=1; break; }
  done

  case "$CANON_BUCKET" in fix|feat|ui|infra|refactor|perf|test|chore|spike) BUCKET_VALID=1 ;; *) BUCKET_VALID=0 ;; esac

  BARE_REPO="$HOME/Developer/$CANON_REPO/.bare"
  if [ "$REPO_VALID" -eq 1 ] \
     && [ "$BUCKET_VALID" -eq 1 ] \
     && [ "$CANON_SLUG" = "$CANON_SLUG2" ] \
     && [ -d "$BARE_REPO" ]; then
    # All checks pass — we can call treekanga directly.
    # Pattern A (ephemeral worktrees, no permanent default-branch worktree):
    #   `git fetch origin --quiet` updates remote-tracking refs only —
    #   does NOT advance local master/develop, so no INDEX drift in
    #   any future or other worktree on those branches.
    #   `-b origin/HEAD` cuts the new branch from the actual upstream
    #   default (master for web, develop for inferno — git resolves
    #   origin/HEAD per-repo automatically).
    #   `-x` runs the postScript hook (sesh/zoxide/install).
    # Single-quote arguments — slug/bucket already validated as alnum-safe.
    FAST_PATH_CMD="cd '$BARE_REPO' && git fetch origin --quiet && treekanga add '$CANON_SLUG' -d '../$CANON_BUCKET' -n '$CANON_SLUG' -b origin/HEAD -x"
  fi
fi

if [ -n "$FAST_PATH_CMD" ]; then
  WORKTREE_RAW_COMMAND="$FAST_PATH_CMD" \
  WORKTREE_GROUP="worktree-${LABEL:-describe}" \
  WORKTREE_LOG_TAG="worktree-prompt" \
  WORKTREE_LOG_HEADER="USER INPUT:    $ORIG_INPUT
FAST PATH (no claude):  $FAST_PATH_CMD" \
  WORKTREE_START_MESSAGE="$ORIG_INPUT (fast-path)" \
  WORKTREE_FALLBACK_LABEL="$ORIG_INPUT" \
  WORKTREE_CAPTURE_PAYLOAD="$ORIG_INPUT" \
  exec ~/.local/bin/worktree-runner
fi

# Slow path — claude does the inference. Use haiku for Mode A
# (Jira URL or bare ticket key) and Mode B (3-token with structured
# branch) since those don't need much reasoning. Use sonnet for
# Mode C (free-text describe — needs the inference power).
SELECTED_MODEL="sonnet"
if [[ "$ORIG_INPUT" =~ ^[[:space:]]*(https://[^/]+\.atlassian\.net/|[A-Z]+-[0-9]+) ]]; then
  SELECTED_MODEL="haiku"
elif read -r -a SLOW_TOKENS <<< "$ORIG_INPUT" && [ "${#SLOW_TOKENS[@]}" -eq 3 ] && [[ "${SLOW_TOKENS[1]}" =~ [0-9] ]]; then
  # Mode B: token 2 has digits → structured branch name like IHRWEB-1234
  SELECTED_MODEL="haiku"
fi

WORKTREE_CLAUDE_INPUT="$INPUT" \
WORKTREE_CLAUDE_MODEL="$SELECTED_MODEL" \
WORKTREE_GROUP="worktree-${LABEL:-describe}" \
WORKTREE_LOG_TAG="worktree-prompt" \
WORKTREE_LOG_HEADER="USER INPUT:    $ORIG_INPUT
CLAUDE INPUT:  $INPUT
MODEL:         $SELECTED_MODEL" \
WORKTREE_START_MESSAGE="$ORIG_INPUT" \
WORKTREE_FALLBACK_LABEL="$ORIG_INPUT" \
WORKTREE_CAPTURE_PAYLOAD="$ORIG_INPUT" \
exec ~/.local/bin/worktree-runner
