[user]
	email = gnohj@users.noreply.github.com
	name = gnohj

[core]
	# Global hooks dir — chezmoi-managed at dot_config/git/hooks/. Currently
	# holds `post-commit` which calls `sb-ticket-log` with the commit subject
	# so every ticket-shaped branch's vault note gets an auto-entry per
	# commit. The hook self-bails on non-ticket branches / no-note cases.
	hooksPath = ~/.config/git/hooks

[alias]
  co = checkout
  cob = checkout -b
  b = branch
  pr = "!f() { git fetch -fu ${2:-upstream} refs/pull/$1/head:pr/$1 && git checkout pr/$1; }; f"
  pr-clean = "!git checkout master ; git for-each-ref refs/heads/pr/* --format=\"%(refname)\" | while read ref ; do branch=${ref#refs/heads/} ; git branch -D $branch ; done"
  dt = "! args=$@; shift $#; nvim -c \"CodeDiff $args\"" # diff view tool

[url "https://"]
  insteadOf = git://

[pull]
	ff = only

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[gpg]
	program = gpg2

[core]
	pager = delta
  excludesfile = ~/.gitignore_global
	# untrackedCache: cache per-directory untracked-file state keyed on mtime so
	# `git status` skips re-scanning unchanged dirs. Big speedup in the web
	# monorepo and it shrinks the index-refresh window (shorter index.lock hold,
	# fewer collisions). Set globally so every clone/worktree on every machine
	# inherits it — reproducible on the Linux vbox too. Caveat: on filesystems
	# with unreliable mtime (e.g. a VirtualBox vboxsf shared-folder mount) this
	# can go stale; clone into the VM's native fs, or `git config core.untrackedCache
	# false` in that one repo if you see phantom untracked entries.
	untrackedCache = true

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3
	tool = codediff

[mergetool "codediff"]
	cmd = nvim "$MERGED" -c "CodeDiff merge \"$MERGED\""
	trustExitCode = true

[mergetool]
	keepBackup = false

[pager]
	diff = delta
	log = delta
	reflog = delta
	show = delta

[include]
	path = ~/.config/delta/themes/themes.gitconfig
[delta]
  features = gnohj-theme
  navigate = true
	line-numbers = true
	side-by-side = true
