#--          Cross-platform shims (Linux VPS / herdr --remote)
#-------------------------------------------------------------------------------
# On non-macOS, define the macOS clipboard/open tools in terms of their Linux
# equivalents so every existing call site (fze, gbc, pullreq, ticket, tmux
# copy-pipe, ‚Ä¶) keeps working untouched. Only defined when the real command is
# absent, so a Linux box that happens to have them installed still wins.
if [[ "$OSTYPE" != darwin* ]]; then
  if ! command -v pbcopy >/dev/null 2>&1; then
    if command -v wl-copy >/dev/null 2>&1; then
      pbcopy() { wl-copy; }
      pbpaste() { wl-paste; }
    elif command -v xclip >/dev/null 2>&1; then
      pbcopy() { xclip -selection clipboard; }
      pbpaste() { xclip -selection clipboard -o; }
    else
      # OSC52: copy to the terminal's (client's) clipboard over any tty ‚ÄĒ ideal
      # over SSH/herdr --remote, where there is no local X/Wayland clipboard.
      pbcopy() { printf '\033]52;c;%s\a' "$(base64 | tr -d '\n')"; }
      pbpaste() { :; }
    fi
  fi
  if ! command -v open >/dev/null 2>&1; then
    open() { xdg-open "$@" >/dev/null 2>&1 & }
  fi
fi

# `up` - one OS-aware command to bring the machine fully up to date. macOS: nix flake update + darwin-rebuild + chezmoi apply + brew + mise. Linux: apt + nix/home-manager + mise + chezmoi. tpm on both; each step banner'd + failure-tolerant.
up() {
  if [[ "$OSTYPE" == darwin* ]]; then
    print -P "%F{cyan}==> nix: flake update + darwin-rebuild switch%f"
    nix flake update --flake ~/.nix || true
    sudo darwin-rebuild switch --flake ~/.nix#macbook_silicon || true

    print -P "%F{cyan}==> chezmoi: apply%f"
    chezmoi apply || true

    print -P "%F{cyan}==> brew: upgrade%f"
    command -v brew >/dev/null 2>&1 && brew upgrade || true

    print -P "%F{cyan}==> mise: self-update + install/upgrade (runtimes + AI agents)%f"
    mise self-update -y 2>/dev/null || true
    mise install || true
    mise upgrade || true
  else
    print -P "%F{cyan}==> apt: system packages%f"
    sudo apt update && sudo apt full-upgrade -y

    print -P "%F{cyan}==> nix: flake update + home-manager switch%f"
    # On Linux ~/.nix is gitignored (no nix-darwin), so the flake lives in the chezmoi source.
    local nixflake="$HOME/.local/share/chezmoi/dot_nix"
    command -v nix >/dev/null 2>&1 && nix flake update --flake "$nixflake" || true
    command -v home-manager >/dev/null 2>&1 && home-manager switch --flake "$nixflake#gnohj-linux-x86_64" || true
    # home-manager doesn't manage the nix daemon; upgrade nix itself (best-effort).
    command -v nix >/dev/null 2>&1 && sudo -i nix upgrade-nix 2>/dev/null || true

    print -P "%F{cyan}==> mise: self-update + toolchain (respects pins in config.toml)%f"
    mise self-update -y 2>/dev/null || true
    mise upgrade || true

    print -P "%F{cyan}==> chezmoi: pull dotfiles + apply (re-fires bootstrap on version bump)%f"
    chezmoi update || true
  fi

  print -P "%F{cyan}==> tpm: tmux plugins%f"
  [ -x "$HOME/.tmux/plugins/tpm/bin/update_plugins" ] && \
    "$HOME/.tmux/plugins/tpm/bin/update_plugins" all || true

  print -P "%F{green}==> up: done%f"
}

# `update` - pull the config repos onto this machine: chezmoi (dotfiles) + the agents and tmux-dash checkouts. Idempotent + fail-safe: missing tools/checkouts and pull failures are reported and skipped, never aborting the rest.
update() {
  local repo name fails=0
  if command -v chezmoi >/dev/null 2>&1; then
    print -P "%F{cyan}==> chezmoi update%f"
    chezmoi update || { print -P "%F{red}   chezmoi update failed - continuing%f"; fails=$((fails + 1)); }
  else
    print -P "%F{8}(skip chezmoi - not installed)%f"
  fi
  if command -v git >/dev/null 2>&1; then
    for repo in "$HOME/Developer/agents" "$HOME/Developer/tmux-dash"; do
      name=${repo:t}
      if [ ! -d "$repo/.git" ]; then
        print -P "%F{8}(skip $name - not cloned here)%f"
        continue
      fi
      print -P "%F{cyan}==> git pull: $name%f"
      git -C "$repo" pull --ff-only --autostash ||
        { print -P "%F{red}   $name pull failed - left untouched (dirty/diverged?)%f"; fails=$((fails + 1)); }
    done
  else
    print -P "%F{8}(skip git pulls - git not installed)%f"
  fi
  if (( fails )); then
    print -P "%F{yellow}==> update: done with $fails issue(s)%f"
  else
    print -P "%F{green}==> update: done%f"
  fi
  return 0
}

