# Blank line before the prompt only when real output sits above it. Starship's own
# `add_newline` is off (see starship*.toml) so it never adds one; instead we print a
# separator in precmd, skipping it whenever the screen was just cleared. Net effect:
# a fresh pane, `clear`/`c`/`reset`, and Ctrl+L all start flush at the top row, but a
# prompt that follows command output gets a blank-line separator. No terminal I/O, so
# nothing can leak to the screen or race with type-ahead.
_prompt_at_top=1
_prompt_blank_precmd() {
    (( _prompt_at_top )) || print
    _prompt_at_top=0
}
_prompt_blank_preexec() {
    case ${1%% *} in
        clear|c|reset) _prompt_at_top=1 ;;
    esac
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd _prompt_blank_precmd
