# mise configuration - Language runtimes ONLY
# https://mise.jdx.dev/configuration.html
#
# Migration strategy (see ~/.local/share/chezmoi/dot_nix/README.md): Nix owns
# system packages & ALL CLI tools; mise (this file) owns language runtimes ONLY;
# Homebrew (nix-darwin) owns macOS-specific apps & services.

[tools]
# Note: Node 22 is also installed for Neovim Copilot (see ~/.config/nvim/lua/plugins/copilot.lua)
node = { version = 'lts', postinstall = 'corepack enable' }
lua = '5.4'
python = 'latest'
go = 'latest'
rust = 'latest'
bun = 'latest'
zig = 'latest'          # used for GhosttyFetch

"npm:prettier" = "latest"
"npm:codeburn" = "latest"

# AI agents on mise `latest` for same-day updates; claude-code + codex are native-binary CLIs needing allow_builds (runs the postinstall that swaps the binary in) + the npm backend (aube's node-shim can't exec a native bin; see npm.package_manager below).
"npm:@anthropic-ai/claude-code" = { version = "latest", allow_builds = ["@anthropic-ai/claude-code"] }
"npm:@openai/codex" = { version = "latest", allow_builds = ["@openai/codex"] }
"npm:@google/gemini-cli" = "latest"
"npm:@earendil-works/pi-coding-agent" = "latest"
"github:rtk-ai/rtk" = "latest"                     # PreToolUse `rtk hook claude`; not in nixpkgs
{{- if ne .chezmoi.os "darwin" }}

# Linux VPS: nix (home-manager, dot_nix/common/package-list.nix) owns the BULK CLI toolchain — the same source the Mac's nix-darwin set pulls from, so both boxes resolve identical binaries from one flake.lock. That deletes the old two-tier mise pin: nvim/yazi/gitmux/sesh/television/atuin + ~15 others now come from nix (nvim & yazi version-parity is the flake.lock's job, not a hand pin).
# mise here owns only what nix deliberately doesn't (AI agents are shared, above):
#   - pnpm (Mac gets it via corepack); treekanga (not in nixpkgs, brew on macOS)
#   - opencode: Linux-only — the Mac install is a separate tangle (its own installer
#     shadows an anomalyco/tap build; sst vs anomalyco forks), left unmerged on purpose.
# NOTE: apply this trim TOGETHER with `home-manager switch --flake ~/.nix#gnohj-linux-x86_64`.
# Applying the trim without home-manager active would drop nvim/rg/etc. off the box.
# starship is NOT here: zinit installs it (gh-r binary + prompt init) on BOTH OSes.
pnpm = "latest"
"github:garrettkrohn/treekanga" = "latest"          # not in nixpkgs; brew on macOS
"github:sst/opencode" = "latest"                   # OpenCode (linux-x64 release binary; Mac has its own installer/brew)
{{- end }}

[tasks]
# aic is configured via chezmoi template at ~/.aicommitrc (see dot_aicommitrc.tmpl);
# uses GitHub Copilot Enterprise via GitHub Models with a dynamic 'gh auth token'.
install-aicommit = "bun add -g @kkidd/aicommit"
setup-global-tools = "mise run install-aicommit"

[settings]
# aube (mise's default npm installer) wraps every npm bin in a `node` shim that can't exec a native-binary CLI (claude-code, codex); the npm backend makes a direct symlink instead.
npm.package_manager = "npm"
auto_install = true
experimental = true
idiomatic_version_file_enable_tools = ["node"]
# 0 opts out of mise 2026.7.12's new 24h minimum_release_age default (keep fast-shipping AI agents same-day; also dodges a mise fallback bug that resolved gemini-cli's `latest` to a bogus version).
minimum_release_age = "0"
# trusted_config_paths intentionally lives in $MISE_TRUSTED_CONFIG_PATHS (~/.zshenv),
# NOT here. mise honors trusted_config_paths ONLY from the GLOBAL config, but this
# exact file is ALSO seen as a NON-global (local) config whenever a shell is cd'd
# inside the chezmoi source tree (mise walks up and finds
# ~/.local/share/chezmoi/dot_config/mise/config.toml). It then warns
# "trusted_config_paths in non-global config ... is ignored for security reasons" on
# every command. Keeping the key out of every config file entirely means that warning
# never fires; the env var provides the same trust with no such restriction.
