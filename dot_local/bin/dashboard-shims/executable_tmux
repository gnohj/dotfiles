#!/usr/bin/env bash
# Wrapper `tmux` for the agent-sidebar-dashboard window. recon's TUI internally calls
# `tmux switch-client -t <session>` (when in tmux) or `tmux attach-session
# -t <session>` (when standalone) on agent-select. Both target recon's own
# terminal — taking over the dashboard window. This shim intercepts those
# two subcommands and rewrites them to target the *primary* tmux client (the
# user's main work window).
#
# After redirecting the switch, the shim re-exec's `recon view` so the
# dashboard window stays alive instead of closing — recon's `Command::exec`
# call replaces its own process with the tmux call, so without this re-exec
# the wrapper would exit and the Ghostty shell would die with it.
#
# The launcher (~/Scripts/agent-sidebar-dashboard.sh) writes the primary client's
# tty path to /tmp/agent-dashboard-primary-client before opening the
# dashboard. Every other tmux subcommand passes through unchanged.

REAL_TMUX="/opt/homebrew/bin/tmux"
RECON="$HOME/.cargo/bin/recon"
AEROSPACE="/opt/homebrew/bin/aerospace"
PRIMARY_FILE="/tmp/agent-dashboard-primary-client"
PRIMARY_WID_FILE="/tmp/agent-dashboard-primary-window"
DASH_WID_FILE="/tmp/agent-dashboard.wid"

PRIMARY=""
[ -r "$PRIMARY_FILE" ] && PRIMARY=$(cat "$PRIMARY_FILE" 2>/dev/null)
PRIMARY_WID=""
[ -r "$PRIMARY_WID_FILE" ] && PRIMARY_WID=$(cat "$PRIMARY_WID_FILE" 2>/dev/null)
DASH_WID=""
[ -r "$DASH_WID_FILE" ] && DASH_WID=$(cat "$DASH_WID_FILE" 2>/dev/null)

case "${1:-}" in
  switch-client|attach-session)
    if [ -n "$PRIMARY" ]; then
      shift
      target=""
      while [ $# -gt 0 ]; do
        case "$1" in
          -t) target="$2"; shift 2 ;;
          -t*) target="${1#-t}"; shift ;;
          *) shift ;;
        esac
      done
      if [ -n "$target" ]; then
        "$REAL_TMUX" switch-client -c "$PRIMARY" -t "$target"
        # Move aerospace focus to the primary window so the user lands on
        # the now-switched session instead of staring at the sidebar.
        [ -n "$PRIMARY_WID" ] && "$AEROSPACE" focus --window-id "$PRIMARY_WID" 2>/dev/null || true
        # Keep the dashboard window alive — re-launch recon view.
        exec "$RECON" view
      fi
    fi
    exec "$REAL_TMUX" "$@"
    ;;
  *)
    exec "$REAL_TMUX" "$@"
    ;;
esac
