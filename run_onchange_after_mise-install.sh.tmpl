#!/bin/bash
# packages hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

set -euo pipefail

MISE_BIN_PATH="{{ if $m := lookPath "mise" }}{{ $m }}{{ else if $l := lookPath (joinPath .chezmoi.homeDir ".local/bin/mise") }}{{ $l }}{{ else }}mise{{ end }}"

if ! command -v "$MISE_BIN_PATH" &>/dev/null; then
  echo "mise not found - skipping. Install mise then run: chezmoi apply"
  exit 0
fi

echo "Mise config changed, running mise trust and install..."

# mise's npm backend reshims by calling bare `mise`, so mise's own bin dir must be
# on PATH — during a fresh bootstrap it isn't (minimal env), so npm-backend tools
# (claude/codex/gemini/prettier) failed reshim with "mise: command not found".
export PATH="{{ .chezmoi.homeDir }}/.local/bin:$PATH"

# Authenticate the github/ubi backends when possible so the toolchain install
# doesn't hit GitHub's 60-req/hr unauthenticated API rate limit. Absent on a
# truly fresh box — then a rate-limited tool just re-runs after `gh auth login`.
if [ -z "${GITHUB_TOKEN:-}" ] && command -v gh >/dev/null 2>&1; then
  GITHUB_TOKEN="$(gh auth token 2>/dev/null || true)"
  [ -n "$GITHUB_TOKEN" ] && export GITHUB_TOKEN
fi

$MISE_BIN_PATH trust {{ .chezmoi.homeDir }}/.config/mise/config.toml
# Non-fatal: a GitHub API rate limit on a fresh box must not abort the whole apply.
if $MISE_BIN_PATH install; then
  echo "Mise tools installed successfully"
else
  echo "!! some mise tools failed (often GitHub API rate limit on a fresh box)."
  echo "   Finish authenticated: gh auth login && GITHUB_TOKEN=\$(gh auth token) mise install"
fi
