#!/usr/bin/env bash
# linux-bootstrap version: 17   (bump to force a re-run on `chezmoi apply`)
#
# System-config + runtime remainder for a Linux VPS. The bulk CLI toolchain (nvim,
# tmux, ripgrep, lazygit, gitmux/sesh, …) now comes from Nix/home-manager, which
# runs BEFORE this script (see linux-vps-setup.sh). PRIMARY path: tmux + agent-tmux-web
# (agents live in tmux; mobile PWA reaches them over Tailscale, laptop over mosh/ssh).
# This script installs what Nix deliberately doesn't: apt system base + monitoring,
# zinit, tpm, ghostty terminfo, mise runtimes/AI agents, tmux-dash + agent-tmux-web.
# Skipped on macOS via .chezmoiignore. The agent-tmux-web service and interactive
# `tailscale up`/`serve` are separate one-time manual steps.
# Every step is best-effort (|| true / guarded) so a hiccup never aborts `chezmoi apply`.
set -uo pipefail

echo "==> Linux system-config + runtime bootstrap (Nix owns the bulk CLIs)"

# 1. mise — runtimes + (via ubi/aqua/cargo backends) most CLIs.
if ! command -v mise >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/mise" ]; then
  echo "==> installing mise"
  curl -fsSL https://mise.run | sh || echo "!! mise install failed — install manually: https://mise.run"
fi
MISE="$(command -v mise 2>/dev/null || echo "$HOME/.local/bin/mise")"

# 2. herdr — agent multiplexer. NOT the primary path (tmux is), installed for
#    experimenting with `herdr --remote`. Best-effort; failure never blocks tmux below.
if ! command -v herdr >/dev/null 2>&1; then
  echo "==> installing herdr (optional — for experimenting; tmux is the primary path)"
  curl -fsSL https://herdr.dev/install.sh | sh || echo "!! herdr install failed — see https://herdr.dev"
fi

# 3. zinit — zsh plugin manager (zshrc self-clones too; seed it here).
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
if [ ! -f "$ZINIT_HOME/zinit.zsh" ] && command -v git >/dev/null 2>&1; then
  echo "==> cloning zinit"
  git clone --depth=1 https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME" || true
fi

# 3c. tpm — tmux plugin manager (zinit's tmux analogue). Clone it so the
#     `run tpm` at the bottom of base.conf doesn't return 127 on a fresh box.
#     Install the plugins once with tmux `prefix + I` (interactive, can't script).
TPM_DIR="$HOME/.config/tmux/plugins/tpm"
if [ ! -e "$TPM_DIR/tpm" ] && command -v git >/dev/null 2>&1; then
  echo "==> cloning tpm (tmux plugin manager)"
  git clone --depth=1 https://github.com/tmux-plugins/tpm "$TPM_DIR" >/dev/null 2>&1 || true
fi

# 3a. Pre-seed GitHub's SSH host key so `git clone`/`ssh -T git@github.com` don't
#     prompt for host-key verification on a fresh box (one interactive `yes` gone).
if command -v ssh-keyscan >/dev/null 2>&1; then
  mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
  if ! grep -q '^github.com ' "$HOME/.ssh/known_hosts" 2>/dev/null; then
    ssh-keyscan -t ed25519 github.com >> "$HOME/.ssh/known_hosts" 2>/dev/null || true
  fi
fi

# 3b. Ghostty terminfo — SSHing from Ghostty sends TERM=xterm-ghostty, which a
#     fresh Ubuntu has no entry for, so `clear`/nvim/lazygit error "unknown terminal
#     type". tic the bundled source (dot_local/share/terminfo-src) into ~/.terminfo
#     so every session just works, no per-box `infocmp | ssh | tic` dance.
TIC_SRC="$HOME/.local/share/terminfo-src/xterm-ghostty.ti"
if [ -f "$TIC_SRC" ] && command -v tic >/dev/null 2>&1 && ! infocmp xterm-ghostty >/dev/null 2>&1; then
  echo "==> installing xterm-ghostty terminfo"
  tic -x "$TIC_SRC" 2>/dev/null || true
fi

# 4. apt base packages — only with passwordless sudo, else print the one-liner.
#    mosh gives roaming laptop attach; python3 is an nvim/tooling dep; wl-clipboard
#    is a best-effort no-op on a headless VPS. tmux itself now comes from Nix
#    (home-manager), pinned to the Mac's version via flake.lock — so it's no longer an
#    apt package or a from-source build, and its build deps (libevent/ncurses/bison) are gone.
# pinentry-curses drives rbw's headless master-password unlock (see step 6b).
# perl: the tmux status-line git-cache refresher (status-git-refresh.sh) strips
# trailing style codes with `perl -pe`; perl-base is essential on Debian/Ubuntu
# anyway, but declare it so a stripped image doesn't leave the git segment blank.
# sysstat + atop: record CPU/mem/swap time-series for the 16-vs-32 GB trial verdict.
# sysstat = CSV-exportable sar history (vps-usage-export.sh); atop = per-process replay.
APT_PKGS="git zsh curl unzip build-essential wl-clipboard python3 perl mosh pinentry-curses sysstat atop figlet pkg-config"
if command -v apt-get >/dev/null 2>&1; then
  if sudo -n true 2>/dev/null; then
    echo "==> apt: $APT_PKGS"
    sudo -n apt-get update -y >/dev/null 2>&1 || true
    sudo -n apt-get install -y $APT_PKGS >/dev/null 2>&1 || true
    # linger: keep tmux + user services alive after logout. Without it logind reaps
    # user processes on last-session-close and "sessions survive" fails. THE key knob.
    echo "==> enabling user linger (services survive logout)"
    sudo -n loginctl enable-linger "$(id -un)" >/dev/null 2>&1 || true

    # zsh as default login shell (mirrors user-setup.sh Phase 3) — else every SSH lands in bash.
    ZSH_BIN="$(command -v zsh || true)"
    if [ -n "$ZSH_BIN" ] && [ "$(getent passwd "$(id -un)" | cut -d: -f7)" != "$ZSH_BIN" ]; then
      echo "==> setting zsh as default login shell"
      sudo -n chsh -s "$ZSH_BIN" "$(id -un)" >/dev/null 2>&1 || echo "   (chsh failed — run: sudo chsh -s $ZSH_BIN $(id -un))"
    fi

    # 4b. Monitoring — turn on the recorders installed above. sysstat is shipped
    #     DISABLED on Debian/Ubuntu and defaults to 10-min sampling; enable it and
    #     tighten to 5-min so short LSP/build spikes register. atop defaults to a
    #     10-min log interval; drop it to 60s for per-process spike forensics.
    #     All best-effort — a missing config file or unit never aborts the apply.
    if [ -f /etc/default/sysstat ]; then
      echo "==> enabling sysstat collection (sar time-series)"
      sudo -n sed -i 's/^ENABLED=.*/ENABLED="true"/' /etc/default/sysstat >/dev/null 2>&1 || true
      # tighten sampling 10m -> 5m: systemd timer on 24.04, cron.d on older releases
      if systemctl list-unit-files 2>/dev/null | grep -q sysstat-collect.timer; then
        sudo -n mkdir -p /etc/systemd/system/sysstat-collect.timer.d >/dev/null 2>&1 || true
        printf '[Timer]\nOnCalendar=\nOnCalendar=*:0/5\n' \
          | sudo -n tee /etc/systemd/system/sysstat-collect.timer.d/override.conf >/dev/null 2>&1 || true
        sudo -n systemctl daemon-reload >/dev/null 2>&1 || true
      elif [ -f /etc/cron.d/sysstat ]; then
        sudo -n sed -i 's#5-55/10#*/5#' /etc/cron.d/sysstat >/dev/null 2>&1 || true
      fi
      sudo -n systemctl enable --now sysstat >/dev/null 2>&1 || true
      sudo -n systemctl enable --now sysstat-collect.timer >/dev/null 2>&1 || true
    fi
    if [ -f /etc/default/atop ]; then
      echo "==> configuring atop (60s per-process log interval)"
      sudo -n sed -i 's/^LOGINTERVAL=.*/LOGINTERVAL=60/' /etc/default/atop >/dev/null 2>&1 || true
      sudo -n systemctl enable --now atop >/dev/null 2>&1 || true
    fi
  else
    echo "==> skip apt + linger + monitoring (no passwordless sudo). Run once yourself:"
    echo "    sudo apt-get update && sudo apt-get install -y $APT_PKGS"
    echo "    sudo loginctl enable-linger $(id -un)"
    echo "    sudo chsh -s \$(command -v zsh) $(id -un)"
    echo "    sudo sed -i 's/^ENABLED=.*/ENABLED=\"true\"/' /etc/default/sysstat && sudo systemctl enable --now sysstat sysstat-collect.timer"
    echo "    sudo sed -i 's/^LOGINTERVAL=.*/LOGINTERVAL=60/' /etc/default/atop && sudo systemctl enable --now atop"
  fi
fi

# 4c. tmux now comes from Nix (home-manager), pinned to the Mac's exact version via
#     flake.lock. The old apt-3.4 + from-source-3.6b build is gone: home-manager runs
#     BEFORE this bootstrap (see linux-vps-setup.sh), so ~/.nix-profile/bin/tmux is
#     already the right version on PATH here — and with apt tmux gone, nothing shadows it.

# 5. Tailscale — private mesh the PWA + laptop reach this box over. Installs binary +
#    daemon only; `tailscale up`/`serve` are interactive one-time steps (see NEXT below).
if ! command -v tailscale >/dev/null 2>&1; then
  echo "==> installing tailscale"
  curl -fsSL https://tailscale.com/install.sh | sh || echo "!! tailscale install failed — see https://tailscale.com/download"
fi

# 6. The whole CLI toolchain (nvim, ripgrep, lazygit, agent CLIs, gitmux/sesh,
#    gh-dash, treehouse/no-mistakes/treekanga, atuin, node/pnpm, …) is DECLARED in
#    the Linux block of ~/.config/mise/config.toml and installed declaratively by
#    run_onchange_after_mise-install.sh (`mise install`), which mise retries — not a
#    best-effort `mise use -g` loop that silently skips a tool on a GitHub blip.
#    rbw is deliberately absent (option B: scoped tokens in ~/.zsh_gnohj_env.local;
#    a full `rbw unlock` stays Mac-only — MANUAL_VPS_SETUP.md security model).

# 6a. Node 22 for Neovim Copilot — copilot.lua pins the interpreter at
#     ~/.local/share/mise/installs/node/22/bin/node (it needs Node 22+); the primary
#     `node` stays lts. Installing 22 is what creates that version-alias path.
if [ -x "$MISE" ] || command -v mise >/dev/null 2>&1; then
  if [ ! -x "$HOME/.local/share/mise/installs/node/22/bin/node" ]; then
    echo "==> installing node@22 (Neovim Copilot interpreter)"
    "$MISE" install node@22 >/dev/null 2>&1 \
      || echo "   (node@22 install failed — Copilot needs it: mise install node@22)"
  fi
fi

# 6b. tmux-dash — PERSONAL PRIVATE repo with no release binaries, so it can't be a
#     declarative mise entry; cargo-built from source (rust comes from the mise
#     config). Needs GitHub repo AUTH on the box first (SSH key, or `gh auth login`
#     + `gh auth setup-git`), so on a fresh box it falls to the manual step below.
if [ -x "$MISE" ] || command -v mise >/dev/null 2>&1; then
  # The tmux popup binds call the absolute ~/.local/bin/tmux-dash (matches macOS), so
  # install there via --root instead of cargo's default ~/.cargo/bin, and gate on that
  # exact path so an older box that built to ~/.cargo/bin gets re-placed on next apply.
  if [ ! -x "$HOME/.local/bin/tmux-dash" ]; then
    echo "==> building tmux-dash from source (Rust, PRIVATE repo — needs repo auth first)"
    "$MISE" exec -- cargo install --git ssh://git@github.com/gnohj/tmux-dash --locked --root "$HOME/.local" >/dev/null 2>&1 \
      || echo "   (tmux-dash is PRIVATE — build by hand once authed: git clone git@github.com:gnohj/tmux-dash && cd tmux-dash && cargo install --path . --root ~/.local)"
  fi
fi

# 9. aic — AI commit-message tool behind lazygit's <c-e>/<c-s>. `setup-global-tools`
#    runs `bun add -g @kkidd/aicommit` (bun auto-installs via mise). Only the fast `aic`
#    path is provisioned; the large-diff `claude -p` fallback stays Mac-only.
if [ -x "$MISE" ] || command -v mise >/dev/null 2>&1; then
  echo "==> mise: aic (AI commit tool)"
  "$MISE" run setup-global-tools >/dev/null 2>&1 \
    || echo "   (skip aic — after 'gh auth login', run: mise run setup-global-tools)"
fi

# 10. Colorscheme seed — generate starship.toml / active-colorscheme.sh / bat cache
#     on a fresh box so the prompt + sesh picker match the Mac instead of falling
#     back to starship's built-in default. Idempotent: skips once an active
#     colorscheme exists (a later `theme` switch owns it). colorscheme-set.sh is
#     OS-aware (guards its macOS-only GUI reloads), so it's safe headless.
CS_SET="$HOME/.config/zshrc/colorscheme-set.sh"
if [ ! -f "$HOME/.config/colorscheme/active/active-colorscheme.sh" ] && [ -x "$CS_SET" ]; then
  echo "==> seeding default colorscheme (evergarden-winter-mute) → prompt + theme files"
  "$CS_SET" evergarden-winter-mute-colors.sh >/dev/null 2>&1 \
    || echo "   (colorscheme seed failed — set by hand: theme  |  colorscheme-set.sh evergarden-winter-mute-colors.sh)"
fi

echo "==> bootstrap done."
echo "    Confirm on PATH: mise git zsh nvim tmux mosh herdr node pnpm claude codex gemini rg fd lazygit yazi jq gh btop delta yq tv gh-dash lazydocker aic"
echo "    LSP servers / tree-sitter parsers install on first nvim launch."
echo "    Monitoring: 'systemctl status sysstat atop' should be active; export with 'vps-usage-export.sh'."
echo "    NEXT (agent-tmux-web route): 'sudo tailscale up --ssh', run 'claude'/'codex' once for OAuth,"
echo "    then clone+build agent-tmux-web (audited, pinned) and expose it tailnet-only via"
echo "    'tailscale serve --bg http://127.0.0.1:6174'."
echo "    ONE-TIME for lazygit AI-commit (<c-e>/<c-s>): run 'gh auth login', then"
echo "    'mise run setup-global-tools' + 'chezmoi apply' (so ~/.aicommitrc gets the token)."
echo "    ONE-TIME for secrets (master password never touches this box): put ONLY the"
echo "    tokens this box needs into ~/.zsh_gnohj_env.local (auto-sourced; var names in"
echo "    ~/.config/bitwarden/vars.txt). Full 'rbw unlock' is reserved for the trusted"
echo "    Mac — see MANUAL_VPS_SETUP.md §Security-4."
