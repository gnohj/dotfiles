#!/usr/bin/env bash
# linux-bootstrap version: 2   (bump to force a re-run on `chezmoi apply`)
#
# Slim toolchain for a Linux VPS running herdr --remote. Installs the FOUNDATION
# (mise, herdr, zinit, apt basics) + a best-effort core CLI set via mise. Nix is
# NOT used on Linux — this is the deliberately-slim, non-Nix path. Skipped on
# macOS via .chezmoiignore.
#
# Every step is best-effort (|| true / guarded) so a network hiccup never aborts
# `chezmoi apply`.
set -uo pipefail

echo "==> Linux slim toolchain bootstrap"

# 1. mise — runtimes + (via ubi/aqua/cargo backends) most CLIs.
if ! command -v mise >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/mise" ]; then
  echo "==> installing mise"
  curl -fsSL https://mise.run | sh || echo "!! mise install failed — install manually: https://mise.run"
fi
MISE="$(command -v mise 2>/dev/null || echo "$HOME/.local/bin/mise")"

# 2. herdr — the agent multiplexer / --remote server.
if ! command -v herdr >/dev/null 2>&1; then
  echo "==> installing herdr"
  curl -fsSL https://herdr.dev/install.sh | sh || echo "!! herdr install failed — see https://herdr.dev"
fi

# 3. zinit — zsh plugin manager (zshrc self-clones too; seed it here).
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
if [ ! -f "$ZINIT_HOME/zinit.zsh" ] && command -v git >/dev/null 2>&1; then
  echo "==> cloning zinit"
  git clone --depth=1 https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME" || true
fi

# 4. apt base packages — only with passwordless sudo, else print the one-liner.
# python3: required by herdr-pane-tracker.py (the prefix+b last-pane daemon) so herdr
# keybinding scripts work over --remote, not just locally. Usually preinstalled on
# Ubuntu/Debian, listed here to guarantee it on a minimal VPS.
APT_PKGS="git zsh curl unzip build-essential wl-clipboard python3"
if command -v apt-get >/dev/null 2>&1; then
  if sudo -n true 2>/dev/null; then
    echo "==> apt: $APT_PKGS"
    sudo -n apt-get update -y >/dev/null 2>&1 || true
    sudo -n apt-get install -y $APT_PKGS >/dev/null 2>&1 || true
  else
    echo "==> skip apt (no passwordless sudo). Run once yourself:"
    echo "    sudo apt-get update && sudo apt-get install -y $APT_PKGS"
  fi
fi

# 5. Core CLIs via mise (best-effort per tool; adjust to taste). These mirror the
#    Mac toolchain so nvim + shell feel identical over --remote.
if [ -x "$MISE" ] || command -v mise >/dev/null 2>&1; then
  echo "==> mise: core CLIs"
  # gh is here because aic (@kkidd/aicommit, the lazygit <c-e>/<c-s> AI-commit
  # tool) authenticates via `gh auth token` — dot_aicommitrc.tmpl reads that token
  # at chezmoi-apply time. Installing gh is not enough: `gh auth login` is a
  # one-time interactive step (can't be scripted) — see the reminder at the end.
  for tool in neovim ripgrep fd fzf lazygit bat eza zoxide starship yazi jq gh; do
    "$MISE" use -g "$tool" >/dev/null 2>&1 || echo "   (skip $tool — check name with 'mise registry')"
  done
  # gitmux + sesh via ubi/aqua backends (no first-party mise registry entry).
  "$MISE" use -g "ubi:arl/gitmux" >/dev/null 2>&1 || echo "   (skip gitmux — install manually)"
  "$MISE" use -g "aqua:joshmedeski/sesh" >/dev/null 2>&1 || echo "   (skip sesh — install manually)"
fi

# 6. aic — AI commit-message tool behind lazygit's <c-e> (gitmoji) / <c-s> (plain)
#    customCommands. `setup-global-tools` runs `bun add -g @kkidd/aicommit`; bun is
#    a mise [tools] entry, so `mise run` auto-installs it first (settings.auto_install).
#    Only the fast `aic` path is provisioned here — the large-diff `claude -p`
#    fallback stays Mac-only (nix-darwin homebrew "claude-code" + per-machine OAuth).
if [ -x "$MISE" ] || command -v mise >/dev/null 2>&1; then
  echo "==> mise: aic (AI commit tool)"
  "$MISE" run setup-global-tools >/dev/null 2>&1 \
    || echo "   (skip aic — after 'gh auth login', run: mise run setup-global-tools)"
fi

echo "==> bootstrap done."
echo "    Confirm on PATH: mise herdr git zsh nvim rg fd lazygit yazi jq gh aic"
echo "    LSP servers / tree-sitter parsers install on first nvim launch."
echo "    ONE-TIME for lazygit AI-commit (<c-e>/<c-s>): run 'gh auth login', then"
echo "    'mise run setup-global-tools' + 'chezmoi apply' (so ~/.aicommitrc gets the token)."
