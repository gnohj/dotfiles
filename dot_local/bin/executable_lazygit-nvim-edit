#!/usr/bin/env bash
# Lazygit custom command for `<C-o>`: open the selected file in the
# nvim that was in the pane behind the popup (RPC), or spawn one if
# none is running. Then auto-close the popup.

set -uo pipefail

# DO NOT try to kill-pane the popup. Tmux popups are not panes —
# display-message returns the host pane instead, and kill-pane on that
# nukes the user's real working pane. Killing the lazygit process via
# process-tree walk is the only safe approach.
find_lazygit_pid() {
  local pid=$$ name
  for _ in 1 2 3 4 5 6; do
    pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
    [ -n "$pid" ] && [ "$pid" != "0" ] && [ "$pid" != "1" ] || return 1
    name=$(ps -o comm= -p "$pid" 2>/dev/null | xargs basename 2>/dev/null)
    if [ "$name" = "lazygit" ]; then
      printf '%s' "$pid"
      return 0
    fi
  done
  return 1
}

DEBUG_LOG="$HOME/.logs/lazygit-nvim-edit.log"
mkdir -p "$(dirname "$DEBUG_LOG")"
{
  printf '=== %s ===\n' "$(date)"
  printf 'arg1: %q\n' "${1:-}"
  printf 'PWD: %s\n' "$PWD"
  printf 'LAZYGIT_HOST_PANE: %q\n' "${LAZYGIT_HOST_PANE:-(unset)}"
  printf 'lazygit pid (process-tree walk): %s\n' "$(find_lazygit_pid || echo '(not found)')"
} >> "$DEBUG_LOG"

FILE="${1:-}"
[ -n "$FILE" ] || { echo "usage: lazygit-nvim-edit <file>" >&2; exit 1; }

# lazygit's {{.SelectedFile.Name}} is repo-relative; resolve against $PWD.
ABS_FILE="$FILE"
if [ "${FILE#/}" = "$FILE" ]; then
  ABS_FILE="$PWD/$FILE"
fi

# Deferred via double-fork because killing lazygit synchronously would
# SIGHUP this script (we're a customCommand subprocess of lazygit).
close_popup_deferred() {
  local lazygit_pid
  lazygit_pid=$(find_lazygit_pid)
  if [ -z "$lazygit_pid" ]; then
    echo "  → could not find lazygit pid; popup will not auto-close" >> "$DEBUG_LOG"
    return 0
  fi
  echo "  → scheduling lazygit SIGTERM: pid=$lazygit_pid (200ms deferred)" >> "$DEBUG_LOG"
  ( ( sleep 0.2; kill -TERM "$lazygit_pid" 2>/dev/null ) </dev/null >/dev/null 2>&1 & ) 2>/dev/null
}

# C-u clears any partial command the user typed before hitting rctrl-g,
# so we never concatenate it with the nvim invocation.
spawn_in_host_pane() {
  local pane="$1"
  local current_cmd
  current_cmd=$(tmux display-message -t "$pane" -p '#{pane_current_command}' 2>/dev/null)
  echo "  host pane $pane current_command: $current_cmd" >> "$DEBUG_LOG"
  case "$current_cmd" in
    bash|zsh|fish|sh|dash|tcsh|ksh)
      tmux send-keys -t "$pane" C-u "nvim '$ABS_FILE'" Enter 2>>"$DEBUG_LOG"
      echo "  → sent nvim launch to host pane $pane (shell: $current_cmd)" >> "$DEBUG_LOG"
      return 0
      ;;
    *)
      # Host pane is running a TUI — send-keys would corrupt its input.
      echo "  → host pane running '$current_cmd'; falling back to new-window" >> "$DEBUG_LOG"
      spawn_in_new_window
      ;;
  esac
}

spawn_in_new_window() {
  echo "  → spawning nvim in new tmux window" >> "$DEBUG_LOG"
  if command -v tmux >/dev/null 2>&1 && tmux ls >/dev/null 2>&1; then
    tmux new-window -c "$(dirname "$ABS_FILE")" "nvim '$ABS_FILE'" >>"$DEBUG_LOG" 2>&1
    echo "  tmux new-window exit: $?" >> "$DEBUG_LOG"
  else
    echo "  → tmux unavailable" >> "$DEBUG_LOG"
  fi
}

# --- herdr path (backwards-compat) ------------------------------------------
# When lazygit runs inside a herdr pane there is no LAZYGIT_HOST_PANE (herdr
# launches lazygit directly, not via lazygit.sh). Instead we ASK herdr for the
# sibling pane in this tab that's running (n)vim, resolve its RPC socket (named
# by init.lua as /tmp/nvim-herdr-<sanitized pane id>.sock), open the file there,
# then close lazygit and refocus that pane. Falls through to the tmux path below
# when not under herdr, so tmux behaviour is unchanged.
herdr_edit_and_exit() {
  local herdr cur_tab host_nvim host_shell info deep key sock dir newp
  herdr="${HERDR_BIN_PATH:-herdr}"
  command -v jq >/dev/null 2>&1 || return 0
  cur_tab=$("$herdr" pane current --current 2>/dev/null | jq -r '.result.pane.tab_id // empty')
  [ -n "$cur_tab" ] || return 0

  # Classify sibling panes in this tab: a running (n)vim (open via its socket),
  # or an IDLE SHELL prompt (deepest foreground process is a bare shell → nothing
  # running, so we can safely send `nvim <file>` into it). Panes running an agent
  # or another TUI are skipped (send-keys would corrupt them).
  host_nvim=""; host_shell=""
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    info=$("$herdr" pane process-info --pane "$pid" 2>/dev/null)
    if printf '%s' "$info" | jq -e '.result.process_info.foreground_processes[]?.name
        | select(test("^(view|l?n?vim?x?)$";"i"))' >/dev/null 2>&1; then
      [ -z "$host_nvim" ] && host_nvim="$pid"
      continue
    fi
    deep=$(printf '%s' "$info" | jq -r '.result.process_info.foreground_processes[-1].name // empty' 2>/dev/null)
    if printf '%s' "$deep" | grep -qiE '^(bash|zsh|fish|sh|dash|ksh|tcsh|nu)$'; then
      [ -z "$host_shell" ] && host_shell="$pid"
    fi
  done < <("$herdr" pane list 2>/dev/null \
    | jq -r --arg t "$cur_tab" --arg self "${HERDR_PANE_ID:-}" \
        '.result.panes[] | select(.tab_id==$t and .pane_id!=$self) | .pane_id')

  # 1) An existing nvim — open the file via its RPC socket (key must match
  #    init.lua: "herdr-" + HERDR_PANE_ID, non-alphanumerics → "-").
  if [ -n "$host_nvim" ]; then
    key="herdr-$(printf '%s' "$host_nvim" | sed 's/[^A-Za-z0-9]/-/g')"
    sock="/tmp/nvim-${key}.sock"
    echo "  herdr nvim pane=$host_nvim sock=$sock exists=$([ -S "$sock" ] && echo yes || echo no)" >> "$DEBUG_LOG"
    if [ -S "$sock" ]; then
      nvim --server "$sock" --remote "$ABS_FILE" >>"$DEBUG_LOG" 2>&1
      "$herdr" pane focus --pane "$host_nvim" >/dev/null 2>&1
      close_popup_deferred
      exit 0
    fi
  fi

  # 2) An idle shell prompt — open nvim IN that pane (reuse it, don't spawn).
  if [ -n "$host_shell" ]; then
    echo "  herdr: opening nvim in idle shell pane $host_shell" >> "$DEBUG_LOG"
    "$herdr" pane send-keys "$host_shell" ctrl+u >/dev/null 2>&1   # clear partial input
    "$herdr" pane send-text "$host_shell" "nvim '$ABS_FILE'" >/dev/null 2>&1
    "$herdr" pane send-keys "$host_shell" enter >/dev/null 2>&1
    "$herdr" pane focus --pane "$host_shell" >/dev/null 2>&1
    close_popup_deferred
    exit 0
  fi

  # 3) Nothing reusable — open the file in a fresh herdr pane split.
  dir=$(dirname "$ABS_FILE")
  newp=$("$herdr" pane split --direction right --cwd "$dir" --focus 2>/dev/null \
    | jq -r '.result.pane.pane_id // .result.pane_id // empty' 2>/dev/null)
  if [ -n "$newp" ]; then
    "$herdr" pane send-text "$newp" "nvim '$ABS_FILE'" >/dev/null 2>&1
    "$herdr" pane send-keys "$newp" enter >/dev/null 2>&1
  fi
  echo "  herdr: no reusable pane; split pane $newp in $dir" >> "$DEBUG_LOG"
  close_popup_deferred
  exit 0
}
if [ -n "${HERDR_PANE_ID:-}" ] && command -v "${HERDR_BIN_PATH:-herdr}" >/dev/null 2>&1; then
  herdr_edit_and_exit
fi

# --- tmux path (unchanged) --------------------------------------------------
PANE_ID="${LAZYGIT_HOST_PANE:-}"
if [ -z "$PANE_ID" ]; then
  spawn_in_new_window
  close_popup_deferred
  exit 0
fi

PANE_NUM="${PANE_ID#%}"
SOCK="/tmp/nvim-${PANE_NUM}.sock"
echo "  resolved SOCK: $SOCK (exists: $([ -S "$SOCK" ] && echo yes || echo no))" >> "$DEBUG_LOG"

if [ ! -S "$SOCK" ]; then
  spawn_in_host_pane "$PANE_ID"
  close_popup_deferred
  exit 0
fi

nvim --server "$SOCK" --remote "$ABS_FILE" >>"$DEBUG_LOG" 2>&1
echo "  nvim --remote exit: $?" >> "$DEBUG_LOG"
close_popup_deferred
