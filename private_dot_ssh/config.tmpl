Host github.com
  AddKeysToAgent yes
{{- if eq .chezmoi.os "darwin" }}
  # macOS: sign with the keychain-held identity key. On the VPS this block is
  # omitted — no private key on the box, git rides the forwarded agent instead.
  IgnoreUnknown UseKeychain
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# dev-box VPS (uncomment + set HostName once the box exists). macOS-only: this is
# a client-side alias for reaching the box, meaningless on the VPS itself.
# ForwardAgent is a convenience for interactive sessions; git push from the box
# rides the box's own per-host key (set by post-provision gh auth), not this agent.
# Host dev-box
#   HostName dev-box.<tailnet>.ts.net
#   User gnohj
#   ForwardAgent yes
#   IdentityFile ~/.ssh/id_ed25519
{{- end }}