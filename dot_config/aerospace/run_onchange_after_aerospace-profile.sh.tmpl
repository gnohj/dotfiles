#!/usr/bin/env bash
# Auto-regen hook: after `chezmoi apply` rewrites aerospace.toml, re-apply the
# active profile so monitor routing isn't silently reset to the chezmoi source.
# The hash comments below embed sha256 of every aerospace source file so any
# change re-triggers this run_onchange script.

# aerospace.toml: {{ include "dot_config/aerospace/private_aerospace.toml" | sha256sum }}
{{ range $f := glob (joinPath .chezmoi.sourceDir "dot_config/aerospace/profiles/*.toml") -}}
# {{ base $f }}: {{ include $f | sha256sum }}
{{ end }}

set -euo pipefail

ACTIVE_FILE="$HOME/.config/aerospace/.active-profile"
SCRIPT="$HOME/.local/bin/aerospace-profile"

# No script yet (first apply on a fresh machine) — nothing to do.
[ -x "$SCRIPT" ] || exit 0

# Default to "laptop" on first run: it covers both laptop-alone and laptop+HP-27er
# via aerospace's monitor-pattern fallback, so it's the safe default on a fresh apply.
PROFILE="$(cat "$ACTIVE_FILE" 2>/dev/null || true)"
[ -z "$PROFILE" ] && PROFILE="laptop"

"$SCRIPT" "$PROFILE"
