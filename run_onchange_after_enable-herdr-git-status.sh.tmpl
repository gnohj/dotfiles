#!/usr/bin/env bash
# Enable the herdr git-status poller via PATH ACTIVATION: herdr-git-status.path starts
# the .service whenever the herdr socket exists, and the poller's --loop exits when it's
# gone — so it runs only while herdr is up, never polling a dead socket. (Keyed off the
# socket, not herdr-server.service, since the real server is usually lazy-spawned.)
#
# run_onchange: the unit hashes below re-run this whenever either unit changes, so
# daemon-reload + the migration below pick up edits. Linux/systemd only — the uname
# guard makes it a clean no-op on macOS (launchd there instead).
#
# service sha256: {{ include "dot_config/systemd/user/herdr-git-status.service" | sha256sum }}
# path    sha256: {{ include "dot_config/systemd/user/herdr-git-status.path" | sha256sum }}
set -eu

[ "$(uname)" = "Linux" ] || exit 0
command -v systemctl >/dev/null 2>&1 || exit 0

systemctl --user daemon-reload
# Migrate off any prior direct .service enablement (default.target / herdr-server.wants).
systemctl --user disable herdr-git-status.service 2>/dev/null || true
systemctl --user enable --now herdr-git-status.path
# Pick up an ExecStart/script change on an already-running instance.
systemctl --user try-restart herdr-git-status.service 2>/dev/null || true
