# brew + mise + mas outdated list
unalias outdated 2>/dev/null
outdated() {
  # Source active colorscheme to get current colors
  source "$HOME/.config/colorscheme/active/active-colorscheme.sh" 2>/dev/null

  # Convert hex to RGB for terminal colors
  local brew_color_hex="${gnohj_color01#\#}"  # Magenta/Purple (brew notification color)
  local mise_color_hex="${gnohj_color03#\#}"  # Blue (mise notification color)
  local mas_color_hex="${gnohj_color12#\#}"   # Yellow (greenish-yellow) (mas notification color)
  local nix_color_hex="${gnohj_color06#\#}"   # Cyan (nix notification color)

  # Convert hex to RGB
  local brew_r=$((16#${brew_color_hex:0:2}))
  local brew_g=$((16#${brew_color_hex:2:2}))
  local brew_b=$((16#${brew_color_hex:4:2}))

  local mise_r=$((16#${mise_color_hex:0:2}))
  local mise_g=$((16#${mise_color_hex:2:2}))
  local mise_b=$((16#${mise_color_hex:4:2}))

  local mas_r=$((16#${mas_color_hex:0:2}))
  local mas_g=$((16#${mas_color_hex:2:2}))
  local mas_b=$((16#${mas_color_hex:4:2}))

  local nix_r=$((16#${nix_color_hex:0:2}))
  local nix_g=$((16#${nix_color_hex:2:2}))
  local nix_b=$((16#${nix_color_hex:4:2}))

  # brew/mas only exist on macOS; skip them entirely on the Linux VPS
  local first=1

  # nix leads ‚ÄĒ it owns the bulk toolchain. No per-package outdated; the signal is flake.lock staleness (`up` resets it).
  if command -v nix >/dev/null 2>&1; then
    (( first )) && first=0 || echo ""
    local nix_flake nix_locked nix_age
    nix_flake="$HOME/.nix"; [ -e "$nix_flake/flake.lock" ] || nix_flake="$HOME/.local/share/chezmoi/dot_nix"
    nix_locked=$(nix flake metadata "$nix_flake" --json 2>/dev/null | jq -r '.locks.nodes.nixpkgs.locked.lastModified // empty')
    if [[ -n "$nix_locked" ]]; then
      nix_age=$(( ($(date +%s) - nix_locked) / 86400 ))
      if (( nix_age >= ${NIX_STALE_DAYS:-7} )); then
        echo "\033[38;2;${nix_r};${nix_g};${nix_b}mnix\033[0m flake ${nix_age}d old ‚ÄĒ run 'up' to bump nixpkgs"
      else
        echo "\033[38;2;${nix_r};${nix_g};${nix_b}mnix\033[0m All tools are up to date (${nix_age}d)"
      fi
    fi
  fi

  if command -v brew >/dev/null 2>&1; then
    (( first )) && first=0 || echo ""
    local brew_outdated=$(brew outdated)
    if [[ -n "$brew_outdated" ]]; then
      echo "$brew_outdated" | awk -v r="$brew_r" -v g="$brew_g" -v b="$brew_b" '{print "\033[38;2;" r ";" g ";" b "mbrew\033[0m package: " $1}'
    else
      echo "\033[38;2;${brew_r};${brew_g};${brew_b}mbrew\033[0m All tools are up to date"
    fi
  fi

  (( first )) && first=0 || echo ""
  local mise_outdated=$(mise outdated 2>/dev/null)
  if [[ -n "$mise_outdated" ]]; then
    echo "$mise_outdated" | awk -v r="$mise_r" -v g="$mise_g" -v b="$mise_b" '{print "\033[38;2;" r ";" g ";" b "mmise\033[0m package: " $1}'
  else
    echo "\033[38;2;${mise_r};${mise_g};${mise_b}mmise\033[0m All tools are up to date"
  fi

  if command -v mas >/dev/null 2>&1; then
    (( first )) && first=0 || echo ""
    local mas_outdated=$(mas outdated)
    if [[ -n "$mas_outdated" ]]; then
      echo "$mas_outdated" | awk -v r="$mas_r" -v g="$mas_g" -v b="$mas_b" '{print "\033[38;2;" r ";" g ";" b "mmas\033[0m package: " $1}'
    else
      echo "\033[38;2;${mas_r};${mas_g};${mas_b}mmas\033[0m All tools are up to date"
    fi
  fi
}

# Set an alias for viewing git diffs with delta
alias gdelta='git diff | delta'

# Review the current branch's PR diff in Hunk (self-review after pushing).
# There's no `hunk diff --pr` flag yet (modem-dev/hunk#465), so resolve the PR's
# base branch dynamically and use the three-dot range base...HEAD ‚ÄĒ i.e. your
# branch's changes vs the merge-base. Worktree-safe (no --git-dir hardcoding).
hpr() {
  local base b
  # 1. the PR's actual base branch ‚ÄĒ most accurate, works in any repo
  base=$(gh pr view --json baseRefName -q .baseRefName 2>/dev/null)
  # 2. origin's default branch (per-repo) when there's no PR yet
  if [ -z "$base" ]; then
    base=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
    base=${base#origin/}
  fi
  # 3. first common default that actually exists on origin
  if [ -z "$base" ]; then
    for b in main master develop trunk; do
      git rev-parse --verify -q "origin/$b" >/dev/null 2>&1 && { base=$b; break; }
    done
  fi
  base=${base:-master}
  git fetch -q origin "$base" 2>/dev/null
  hunk diff "origin/${base}...HEAD"
}

# cd to default branch worktree from bare repo
cdm() {
  if [[ ! -d ".git" ]]; then
    echo "Not in a bare repo directory"
    return 1
  fi
  if [[ "$(git --git-dir=.git rev-parse --is-bare-repository 2>/dev/null)" != "true" ]]; then
    echo "Not in a bare repo directory"
    return 1
  fi
  local default_branch=$(git --git-dir=.git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
  if [[ -z "$default_branch" ]]; then
    echo "Could not detect default branch"
    return 1
  fi
  local worktree=$(git --git-dir=.git worktree list | grep "\[$default_branch\]" | awk '{print $1}')
  if [[ -z "$worktree" ]]; then
    echo "No worktree found for branch: $default_branch"
    return 1
  fi
  cd "$worktree"
}

# List (and with -r, return) ORPHANED treehouse pool leases: slots that are
# leased but have NO tmux pane sitting inside them ‚ÄĒ the gh-dash review or
# orchestrator agent that borrowed the slot is gone, so it's silently holding
# pool capacity (the leak that stranded 19153/19179 before). Reads treehouse's
# own per-pool state files, so it spans EVERY pool (web review, inferno,
# orchestration) regardless of cwd. Complements gh-dash `R` (review pool only)
# and tkrm.
#   treehouse-orphans        list orphaned leases
#   treehouse-orphans -r     return them (treehouse return --force)
treehouse-orphans() {
  command -v jq >/dev/null 2>&1 || { echo "treehouse-orphans: needs jq"; return 1; }
  local return_them=0
  [[ "$1" == "-r" || "$1" == "--return" ]] && return_them=1
  local panes; panes="$(tmux list-panes -a -F '#{pane_current_path}' 2>/dev/null)"
  local found=0 wt holder since procs
  while IFS=$'\t' read -r wt holder since; do
    [[ -n "$wt" ]] || continue
    # In use if any pane's cwd is the worktree or a subdir of it ‚Üí not an orphan.
    if printf '%s\n' "$panes" | awk -v w="$wt" '$0==w||index($0,w"/")==1{f=1}END{exit f?0:1}'; then
      continue
    fi
    found=1
    procs=$(lsof -d cwd -Fn 2>/dev/null | grep -c "^n${wt}" || true)
    printf 'ūüĆ≤ %-26s %s  (leased %s, %s zombie proc)\n' "$holder" "$wt" "${since%%T*}" "${procs:-0}"
    if (( return_them )); then
      case "$holder" in
        review-*)
          # gh-dash review lease ‚Üí use its own release so the gh-review state
          # file is cleaned too (raw `treehouse return` would leave it dangling).
          if "$HOME/.config/gh-dash/review-worktree.sh" release "${holder#review-}" >/dev/null 2>&1; then
            echo "   ‚Ü≥ released"
          else
            echo "   ‚Ü≥ release failed"
          fi
          ;;
        *)
          if ( cd "$wt" 2>/dev/null && treehouse return "$wt" --force ) >/dev/null 2>&1; then
            echo "   ‚Ü≥ returned"
          else
            echo "   ‚Ü≥ return failed ‚ÄĒ try: treehouse return \"$wt\" --force"
          fi
          ;;
      esac
    fi
  done < <(find "$HOME/.treehouse" -maxdepth 2 -name treehouse-state.json 2>/dev/null \
    -exec jq -r '.worktrees[]? | select(.leased==true) | "\(.path)\t\(.lease_holder // "?")\t\(.leased_at // "?")"' {} + 2>/dev/null)
  if (( ! found )); then
    echo "ūüĆ≤ no orphaned treehouse leases"
  elif (( ! return_them )); then
    echo "   run 'treehouse-orphans -r' to return them"
  fi
}

# Housekeeping companion to treehouse-orphans: sweep STALE worktrees across every
