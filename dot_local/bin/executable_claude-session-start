#!/usr/bin/env bash
# Claude Code SessionStart hook: surface relevant second-brain vault notes for
# the current work-repo + ticket. Replaces the soft "session-start trigger"
# guidance in ~/.claude/CLAUDE.md with a deterministic, hook-driven injection.
#
# Input (stdin): JSON from Claude Code with .cwd, .source, .session_id, etc.
# Output (stdout): plain text; Claude Code injects it as additionalContext.
#                  Empty stdout = no context added (silent no-op).
#
# Exit non-zero is treated as a hook error by Claude Code — we always exit 0.

set -uo pipefail

# Read hook payload from stdin (small JSON, no streaming needed).
input=$(cat 2>/dev/null || true)
cwd=$(jq -r '.cwd // empty' <<<"$input" 2>/dev/null || true)
src=$(jq -r '.source // empty' <<<"$input" 2>/dev/null || true)

# Resolve the active vault from cwd: work repo → second-brain-work, else personal (surfaces the right ticket/hot-path notes).
VAULT="$("$HOME/.local/bin/vault-path" "$cwd")"

# Only fire on fresh sessions / resumes. /clear and /compact already have the
# trigger's effect baked into the user's expectation that context just changed,
# so re-injecting there is noise.
case "$src" in
  startup|resume) ;;
  *) exit 0 ;;
esac

# Bail if cwd or vault isn't reachable.
[ -n "$cwd" ] && [ -d "$cwd" ] && [ -d "$VAULT" ] || exit 0

# Detect tracked work repo by cwd prefix. Mirror the list in ~/.claude/CLAUDE.md
# "Session-start trigger" section.
repo=""
case "$cwd/" in
  "$HOME/Developer/web/"*)     repo="web" ;;
  "$HOME/Developer/inferno/"*) repo="inferno" ;;
  "$HOME/Developer/actions/"*) repo="actions" ;;
  *) exit 0 ;;
esac

# Extract ticket key from branch (e.g. IHRWEB-23643 from feat/IHRWEB-23643-foo).
branch=$(git -C "$cwd" branch --show-current 2>/dev/null || true)
ticket=$(printf '%s' "$branch" | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)

notes=()

# Ticket-specific why-history notes. Glob BOTH Notes/work/ (post-ingest) and
# Notes-Inbox/ (pre-ingest captures from /sb-ticket-capture) so a freshly
# captured note still gets surfaced before /sb-ingest-mine has filed it. See
# memory `feedback-session-start-check-inbox-too`. Match `<KEY>.md` (no slug)
# and `<KEY>-*.md` (with slug) — both naming forms appear in practice.
if [ -n "$ticket" ]; then
  while IFS= read -r -d '' f; do notes+=("$f"); done < <(
    find "$VAULT/Notes/work" "$VAULT/Notes-Inbox" -maxdepth 1 -type f \
      \( -name "${ticket}.md" -o -name "${ticket}-*.md" \) -print0 2>/dev/null
  )
fi

# Per-repo hot-path notes. Keep this list in sync with the per-repo section in
# ~/.claude/CLAUDE.md ("hot-path notes (read eagerly when the topic comes up)").
case "$repo" in
  web)
    candidates=(
      "$VAULT/Notes/fact/2026-05-09_Polaris-i18n-Fastly-Geo-Flow.md"
      "$VAULT/Notes/work/IHRWEB-23643-re-pulumi-phase-1.md"
      "$VAULT/Notes/work/2026-05-24_Hybrid-Target-Type-Design-fastly_compute_radioedit.md"
    )
    for c in "${candidates[@]}"; do
      [ -e "$c" ] && notes+=("$c")
    done
    ;;
esac

# Dedupe (a ticket note can also be a hot-path note, e.g. IHRWEB-23643).
if [ ${#notes[@]} -gt 0 ]; then
  mapfile -t notes < <(printf '%s\n' "${notes[@]}" | awk '!seen[$0]++')
fi

# Detect "ticket-branch with no captured vault note" — used below to emit a
# directive instructing the agent to run /sb-ticket-capture as its first action.
# This closes the capture gap surfaced by /sb-usage: tickets that were never
# captured at all (vs. captured-but-hook-missed, which the inbox-glob already
# handles). Determined by checking whether any entry in `notes` matches the
# current ticket's filename pattern, NOT whether `notes` is non-empty — a
# session can match the static web hot-paths without having a ticket-specific
# note.
ticket_note_missing=false
if [ -n "$ticket" ]; then
  ticket_note_missing=true
  for n in "${notes[@]}"; do
    base="${n##*/}"
    case "$base" in
      "${ticket}.md"|"${ticket}-"*.md)
        ticket_note_missing=false
        break
        ;;
    esac
  done
fi

# Nothing to surface? Exit quietly — no context, no noise.
[ ${#notes[@]} -eq 0 ] && [ ! -e "$VAULT/index.md" ] && [ "$ticket_note_missing" = "false" ] && exit 0

# Emit context. Plain text on stdout becomes additionalContext per Claude Code
# hooks contract (https://code.claude.com/docs/en/hooks).
{
  echo "## Second-brain vault context (auto-injected by SessionStart hook)"
  echo ""
  echo "Repo: \`$repo\` · Branch: \`$branch\` · Ticket: ${ticket:-none}"
  echo ""
  if [ ${#notes[@]} -gt 0 ]; then
    echo "**Read these BEFORE the first codebase grep/Read on any non-trivial question** — they hold why-history (design intent, prior dead-ends, gotchas) that the code does not capture:"
    echo ""
    for n in "${notes[@]}"; do
      lines=$(wc -l <"$n" 2>/dev/null | tr -d ' ' || echo "?")
      echo "- \`$n\` (${lines} lines)"
    done
    echo ""
  fi
  # Vault orientation files — applies to ALL tracked work repos (web, inferno,
  # actions). These are the meta files the agent would Read anyway via
  # discovery (per global ~/.claude/CLAUDE.md Second-Brain Vault rules); listing
  # them here makes the load deterministic instead of discovery-driven, so cold
  # sessions don't have to navigate to find them.
  orient_files=(
    "$VAULT/CLAUDE.md:vault protocols (hubs, tags, write rules)"
    "$VAULT/index.md:one-line map of every distilled note"
    "$VAULT/log.md:cross-session activity log (newest-first)"
    "$VAULT/Notes-Meta/_hubs.md:hub / tag overview"
  )
  orient_any=false
  for entry in "${orient_files[@]}"; do
    p="${entry%%:*}"
    [ -e "$p" ] && orient_any=true && break
  done
  if [ "$orient_any" = "true" ]; then
    echo "**Vault orientation** (load these for vault layout + recent activity):"
    echo ""
    for entry in "${orient_files[@]}"; do
      p="${entry%%:*}"
      desc="${entry#*:}"
      [ -e "$p" ] && echo "- \`$p\` — $desc"
    done
    echo ""
  fi
  if [ "$ticket_note_missing" = "true" ]; then
    echo "⚠ **No vault note exists for ${ticket}.** As your first action this session, run \`/sb-ticket-capture\` to fetch the Jira ticket (description, acceptance criteria, linked issues) and write a distilled context note to \`Notes-Inbox/\`. This grounds the rest of the session in why-history rather than blind code-exploration. Do this BEFORE any non-trivial codebase Read/Grep."
    echo ""
  fi
  echo "Vault-vs-code authority: code is source of truth for current behavior; vault is for intent + history. When they disagree, code wins — surface the drift."
} 2>/dev/null

exit 0
