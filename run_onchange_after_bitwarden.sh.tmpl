#!/usr/bin/env bash
# Secret list hash: {{ include "dot_config/bitwarden/vars.txt" | sha256sum }}
# Re-runs when vars.txt changes; fetches all secrets from Bitwarden into a
# separate file sourced by ~/.zsh_gnohj_env.

set -euo pipefail

echo "Secret list changed, fetching from Bitwarden..."

if ! command -v rbw &> /dev/null; then
  echo "Error: rbw not found. Install via nix-darwin."
  exit 1
fi

# Check if vault is unlocked - exit 0 (not 1) so chezmoi apply doesn't fail.
# Secrets simply won't be populated; run 'eval $(rbw unlock) && chezmoi apply' to retry.
if ! rbw unlocked &> /dev/null; then
  echo "Bitwarden vault is locked - skipping secret fetch."
  echo "To populate secrets: eval \$(rbw unlock) && chezmoi apply"
  exit 0
fi

# Sync vault (non-fatal — local cache may already be up to date)
echo "Syncing Bitwarden vault..."
rbw sync || echo "Warning: rbw sync failed, continuing with local cache"

SECRETS_FILE="{{ .chezmoi.homeDir }}/.zsh_gnohj_env.secrets"
echo "# Generated by chezmoi from Bitwarden - DO NOT EDIT" > "$SECRETS_FILE"
echo "# Last updated: $(date)" >> "$SECRETS_FILE"
echo "" >> "$SECRETS_FILE"

{{ range (include "dot_config/bitwarden/vars.txt" | trim | splitList "\n") -}}
echo "Fetching {{ . }}..."
SECRET_VALUE=$(rbw get "{{ . }}" 2>/dev/null || echo "")
if [ -n "$SECRET_VALUE" ]; then
  echo 'export {{ . }}="'"$SECRET_VALUE"'"' >> "$SECRETS_FILE"
else
  echo "Warning: {{ . }} not found in Bitwarden"
fi
{{ end }}

chmod 600 "$SECRETS_FILE"

echo "✓ Secrets written to $SECRETS_FILE (permissions: 600)"
echo "Run 'source ~/.zshrc' to load updated secrets"
