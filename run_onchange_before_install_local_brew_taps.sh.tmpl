#!/usr/bin/env bash
#
# Mirrors local Homebrew taps from chezmoi into Homebrew's taps directory
# so that nix-darwin's `homebrew.taps` entries with local clone_targets resolve.
#
# Re-runs whenever any cask under dot_nix/nix-darwin/local-taps/ changes.
# Hash file CONTENTS (not paths) so edits to existing .rb files re-trigger:
{{- range (glob (joinPath .chezmoi.sourceDir "dot_nix/nix-darwin/local-taps/**/*.rb")) }}
# {{ . }}: {{ include . | sha256sum }}
{{- end }}

set -e

{{- if ne .chezmoi.os "darwin" }}
echo "🚧 Skipping local-tap install (not macOS)"
exit 0
{{- end }}

if ! command -v brew >/dev/null 2>&1; then
  echo "❌ brew not found; skipping local-tap install"
  exit 0
fi

BREW_PREFIX="$(brew --prefix)"
SRC_TAPS_DIR="{{ .chezmoi.sourceDir }}/dot_nix/nix-darwin/local-taps"

echo "
🍺 Run OnChange [Before] Local Brew Taps........"

for tap_src in "$SRC_TAPS_DIR"/*/; do
  [ -d "$tap_src" ] || continue
  tap_name="$(basename "$tap_src")"          # e.g. "gnohj-pinned"
  user="${tap_name%%-*}"                      # "gnohj"
  repo="${tap_name#*-}"                       # "pinned"
  dst="$BREW_PREFIX/Library/Taps/$user/homebrew-$repo"

  mkdir -p "$dst"
  rsync -a --delete --exclude='.git' "$tap_src" "$dst/"

  if [ ! -d "$dst/.git" ]; then
    (
      cd "$dst"
      git init -q
      git -c user.email=local@local -c user.name=local add -A
      git -c user.email=local@local -c user.name=local commit -q -m "init local tap" >/dev/null
    )
  else
    (
      cd "$dst"
      if ! git -c user.email=local@local -c user.name=local diff --quiet HEAD -- 2>/dev/null; then
        git -c user.email=local@local -c user.name=local add -A
        git -c user.email=local@local -c user.name=local commit -q -m "sync local tap" >/dev/null || true
      fi
    )
  fi

  echo "✅ Synced local tap: $user/$repo → $dst"
done

echo "🎉 Local Brew Taps sync complete"
