#!/usr/bin/env bash
# Opencode resume. Two modes:
#   ocr <session-id>  resume that session directly in this pane (opencode -s).
#   ocr               open nvim -> Opencode Sessions picker; on pick, quit nvim
#                     and resume that session in THIS SAME pane (AI_PICK_FILE
#                     handoff). Selecting nothing just leaves you in nvim.

if [ "$#" -gt 0 ]; then
  exec opencode -s "$@"
fi

sel=$(mktemp -t ocr-pick.XXXXXX)
AI_PICK_FILE="$sel" nvim -c "lua vim.schedule(function() require('plugins.snacks.ai_sessions').opencode() end)"
id=$(cat "$sel" 2>/dev/null)
rm -f "$sel"
[ -n "$id" ] && exec opencode -s "$id"
