#!/usr/bin/env bash
# Re-run setup-worktrees so existing boxes pick up bare-worktree fixes without a full user-setup.sh.
# Its ensure_upstreams() repairs local heads that `git worktree add` left with no tracking config
# (the "Cannot fast-forward a branch with no upstream" lazygit error). Already-bare repos do zero
# network here — ref reads + config writes only — so this is cheap enough for every apply.
#
# run_onchange: the hash below re-runs this whenever the script itself changes. Cross-platform;
# no-ops when the private manifest is absent (fresh box before ~/.config/worktree-repos.local).
#
# setup-worktrees sha256: {{ include "dot_local/bin/executable_setup-worktrees" | sha256sum }}
set -eu

[ -x "$HOME/.local/bin/setup-worktrees" ] || exit 0
[ -f "${WORKTREE_REPOS_FILE:-$HOME/.config/worktree-repos.local}" ] || exit 0

"$HOME/.local/bin/setup-worktrees" || true
