# tmux-dash dashboard. Bare `td` hosts the default tmux server; `td attach <name>`
# targets a separate server/socket (e.g. `td attach personal` / `td attach work`)
# whose agents are fully isolated from the default's ‚ÄĒ forwarded to the binary's
# `-L <name>` flag. Any other args pass straight through.
td() {
  local sock=()
  if [[ "$1" == "attach" && -n "$2" ]]; then
    sock=(-L "$2"); shift 2
  fi
  z ~/Developer/tmux-dash && cargo run --release -- "${sock[@]}" "$@"
}

