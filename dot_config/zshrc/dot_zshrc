# Function to update starship prompt/config and environment based on current repo
function update_starship_env() {
  # One `git rev-parse` for everything, and zero coreutil spawns. `--show-toplevel`
  # errors (non-zero exit) in a bare repo or outside a work tree, so the whole
  # call drops straight to the default-config fallback ‚ÄĒ the same result the old
  # explicit is_bare/in_tree branch produced, minus a probe. Runs on every cd and
  # on shell startup, so trimming the ~4 subprocess spawns (2nd rev-parse +
  # basename + dirname) matters in the big monorepos where each git spawn is slow.
  local git_info
  git_info=$(git rev-parse --is-bare-repository --is-inside-work-tree --git-common-dir --show-toplevel 2>/dev/null) || {
    export STARSHIP_CONFIG=~/.config/starship/starship.toml
    unset RADIO_CTL AWS_PROFILE
    return
  }
  local -a gi=("${(@f)git_info}")
  local is_bare=$gi[1] in_tree=$gi[2] git_common_dir=$gi[3] toplevel=$gi[4]

  # Bare repo (worktree parent) or not inside a work tree: default config.
  if [[ "$is_bare" == "true" || "$in_tree" != "true" ]]; then
    export STARSHIP_CONFIG=~/.config/starship/starship.toml
    unset RADIO_CTL AWS_PROFILE
    return
  fi

  # basename via zsh :t modifier ‚ÄĒ no subprocess.
  local repo_name=${toplevel:t}

  # For worktrees, use the bare repo name from git-common-dir
  # git-common-dir returns path like /path/to/inferno/.bare for worktrees;
  # :h:t is dirname-then-basename with no subprocess.
  if [[ "$git_common_dir" != ".git" && ("$git_common_dir" == */.git || "$git_common_dir" == */.bare) ]]; then
    repo_name=${git_common_dir:h:t}
  fi

  # Only use infra config for web and inferno
  if [[ "$repo_name" == "web" || "$repo_name" == "inferno-monorepo" || "$repo_name" == "inferno" ]]; then
    export STARSHIP_CONFIG=~/.config/starship/starship-infra.toml
    if [[ "$repo_name" == "inferno-monorepo" || "$repo_name" == "inferno" ]]; then
      export AWS_PROFILE="inferno"
    elif [[ "$repo_name" == "web" ]]; then
      export AWS_PROFILE="ihr-prod"
    fi
    local radio_ctl_prompt=$(typeset -f get_rc >/dev/null && get_rc || echo 1)
    if [[ $radio_ctl_prompt != 1 ]]; then
      export RADIO_CTL="$radio_ctl_prompt"
    else
      unset RADIO_CTL
    fi
  else
    export STARSHIP_CONFIG=~/.config/starship/starship.toml
    unset RADIO_CTL AWS_PROFILE
  fi
}

