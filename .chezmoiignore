# Generated at runtime by generate-tmux-colors.sh (run-shell on tmux start,
# prefix+r reload, and colorscheme-set.sh). Self-rewrites a `# Generated at:`
# timestamp on every run and re-resolves @chip_* from the active colorscheme,
# so tracking it as source guarantees perpetual `chezmoi diff` drift.
.config/tmux/tmux-colors.conf

# Generated at runtime by colorscheme-set.sh (generate_ghostty_theme /
# generate_kitty_theme) - re-resolved from the active colorscheme on every theme
# switch, so tracking them as source guarantees perpetual `chezmoi diff` drift.
# colorscheme-set.sh is the sole owner (same pattern as tmux-colors.conf above).
.config/ghostty/ghostty-theme
.config/kitty/kitty-theme.conf

# Python bytecode caches — CPython rewrites these .pyc files (embedding source
# hash + mtime) every time the herdr-*.py helpers run, so tracking them as source
# guarantees perpetual `chezmoi diff` drift. Never manage them; each machine
# regenerates its own on first run.
**/__pycache__
**/__pycache__/**
**/*.pyc

# Local dev auth — per-machine mkcert artifacts (private key + cert).
# Never managed by chezmoi: each developer generates their own cert+key
# pair locally via mkcert, signed by their own machine-local root CA.
# Sharing the private key would let anyone impersonate `*.local.inferno.*`.
.local-dev-auth
.local-dev-auth/**

