#!/usr/bin/env bash
# Prints "city-stateabbrev" (e.g. austin-tx) from the machine's public-IP
# geolocation, for the tmux host cell (host_short@city). Fully dynamic: when a
# box relocates (Dallas -> Atlanta) its public IP changes and this re-resolves
# on its own — nothing to edit. Cached ~1h so the status bar never forks a
# network call per refresh; on a network failure it prints the last known value.
# Cross-platform (macOS + Linux).

set -uo pipefail

CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/host-city"
TTL=3600

# GNU stat first: its -f means "filesystem", not "format", so the BSD probe
# `stat -f %m` does NOT fail cleanly on Linux - it prints filesystem info
# ("File: ...") to stdout AND exits 1, so the || fallback appended a valid
# mtime to that garbage and the caller's $(( )) blew up under set -u. BSD stat
# has no -c at all, so it errors silently to stderr and falls through.
file_mtime() {
  local m
  m="$(stat -c %Y "$1" 2>/dev/null)" || m="$(stat -f %m "$1" 2>/dev/null)" || m=0
  case "$m" in '' | *[!0-9]*) m=0 ;; esac
  printf '%s' "$m"
}

# Fresh cache -> print it, skip the network entirely.
if [ -f "$CACHE" ] && [ "$(( $(date +%s) - $(file_mtime "$CACHE") ))" -lt "$TTL" ]; then
  cat "$CACHE"
  exit 0
fi

# ip-api.com returns the state ABBREV in .region (e.g. TX), which is what we want.
# Parse with sed (NOT jq): jq is a mise tool that isn't on PATH in tmux's bare
# run-shell env on a fresh box, so a jq pipe silently yields an empty city. curl
# lives in /usr/bin on both platforms, so this only depends on that.
resp="$(curl -s --max-time 4 'http://ip-api.com/json/?fields=status,city,region' 2>/dev/null || true)"
val() { printf '%s' "$resp" | sed -n "s/.*\"$1\":\"\([^\"]*\)\".*/\1/p"; }
city=""
if [ "$(val status)" = "success" ]; then
  city="$(printf '%s-%s' "$(val city)" "$(val region)" \
    | tr 'A-Z ' 'a-z-' \
    | tr -cd 'a-z0-9-')"
fi

if [ -n "$city" ] && [ "$city" != "-" ]; then
  mkdir -p "$(dirname "$CACHE")"
  printf '%s' "$city" >"$CACHE"
  printf '%s' "$city"
elif [ -f "$CACHE" ]; then
  cat "$CACHE"   # network failed -> last known location
fi
