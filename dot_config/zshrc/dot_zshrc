  # (every cd). The precmd hook re-runs hook-env after every command ‚ÄĒ ~8-10ms
  # of config parsing + tool-state loading each time ‚ÄĒ even when the directory
  # never changed. Tool/env switching only actually needs to happen on cd, which
  # chpwd already covers, and the one-shot resolve `mise activate` runs at load
  # handles the current shell's startup dir. So drop precmd and keep chpwd.
  #
  # Tradeoff: editing a `.mise.toml`/`.nvmrc` in place no longer reloads the
  # current shell until you cd out-and-back (or open a new shell). Acceptable for
  # a worktree workflow where tool pins rarely change under a live shell.
  autoload -Uz add-zsh-hook
  add-zsh-hook -d precmd _mise_hook_precmd 2>/dev/null
fi

